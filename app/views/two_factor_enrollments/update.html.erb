<main class="mx-auto max-w-2xl p-6 text-right" dir="rtl">
  <h1 class="text-2xl font-bold"><%= t("security.two_factor.recovery_title") %></h1>
  <p class="mt-3"><%= t("security.two_factor.recovery_warning") %></p>
  <ul class="mt-5 grid grid-cols-2 gap-2 font-mono" aria-label="<%= t("security.two_factor.recovery_title") %>">
    <% @recovery_codes.each do |code| %><li><%= code %></li><% end %>
  </ul>
  <%= link_to t("security.two_factor.continue"), root_path, class: "mt-6 inline-block rounded bg-emerald-700 px-5 py-3 text-white" %>
</main>
