<main class="mx-auto max-w-lg p-6 text-right" dir="rtl">
  <h1 class="text-2xl font-bold"><%= t("security.two_factor.enroll_title") %></h1>
  <p class="mt-3"><%= t("security.two_factor.enroll_help") %></p>
  <%= form_with url: two_factor_enrollment_path, class: "mt-6 space-y-4" do |form| %>
    <%= form.label :current_password, t("security.two_factor.current_password"), class: "block" %>
    <%= form.password_field :current_password, required: true, autocomplete: "current-password", class: "w-full rounded border p-3" %>
    <%= form.submit t("security.two_factor.begin"), class: "rounded bg-emerald-700 px-5 py-3 text-white" %>
  <% end %>
</main>
