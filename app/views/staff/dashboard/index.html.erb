<% content_for :title, "لوحة العمليات" %><div class="mx-auto max-w-7xl px-4 py-10"><h1 class="text-3xl font-black">لوحة عمليات الصيدلية</h1><p class="mt-2 text-slate-600">ملخص عملي للطلبات التي تحتاج إجراءً.</p><div class="mt-7 grid gap-4 sm:grid-cols-2 lg:grid-cols-4"><%= link_to staff_prescriptions_path, class: "rounded-2xl bg-white p-5 shadow-sm" do %><span class="text-sm text-slate-500">روشتات تنتظر المراجعة</span><strong class="mt-2 block text-3xl"><%= @awaiting_prescriptions %></strong><% end %><% [["طلبات جديدة", "submitted"], ["قيد التجهيز", "preparing"], ["جاهزة للتوصيل", "ready_for_delivery"]].each do |label, status| %><%= link_to staff_orders_path(status:), class: "rounded-2xl bg-white p-5 shadow-sm" do %><span class="text-sm text-slate-500"><%= label %></span><strong class="mt-2 block text-3xl"><%= @counts[status] %></strong><% end %><% end %></div><div class="mt-5 rounded-2xl border border-amber-200 bg-amber-50 p-5"><strong><%= @active_reservations %></strong> حجز مخزون نشط يحتاج متابعة تشغيلية.</div></div>
