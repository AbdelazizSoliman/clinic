<div class="mx-auto max-w-5xl px-4 py-10"><p class="text-sm text-slate-500">مهمة الطلب <%= @fulfilment.order.number %></p><h1 class="mt-2 text-3xl font-black">التجهيز والتوصيل</h1><div class="mt-7 grid gap-6 lg:grid-cols-2"><section class="rounded-3xl bg-white p-6"><h2 class="text-xl font-black">بيانات المهمة</h2><dl class="mt-4 space-y-3"><div><dt class="text-slate-500">الحالة</dt><dd class="font-black"><%= @fulfilment.status.humanize %></dd></div><div><dt class="text-slate-500">المنطقة</dt><dd><%= @fulfilment.delivery_zone.name %></dd></div><div><dt class="text-slate-500">المسؤول</dt><dd><%= @fulfilment.assigned_to&.full_name || "غير مسند" %></dd></div></dl></section><section class="rounded-3xl bg-white p-6"><h2 class="text-xl font-black">إسناد المهمة</h2><%= form_with url: assign_staff_fulfilment_path(@fulfilment), method: :patch, class: "mt-4 space-y-3" do |f| %><%= hidden_field_tag :lock_version, @fulfilment.lock_version %><%= select_tag :assigned_to_id, options_from_collection_for_select(User.where(active: true, role: %i[order_manager admin]), :id, :full_name, @fulfilment.assigned_to_id), include_blank: "اختر المسؤول", class: "w-full rounded-xl border p-3" %><%= f.submit "إسناد", class: "rounded-xl bg-pharmacy-600 px-5 py-3 font-black text-white" %><% end %><% next_status = { "assigned" => "picking", "picking" => "packed", "packed" => "dispatched", "dispatched" => "delivered" }[@fulfilment.status] %><% if next_status %><%= button_to "الانتقال إلى #{next_status.humanize}", transition_staff_fulfilment_path(@fulfilment), method: :patch, params: { to_status: next_status, lock_version: @fulfilment.lock_version }, class: "mt-4 rounded-xl border px-5 py-3 font-bold" %><% end %></section></div></div>
