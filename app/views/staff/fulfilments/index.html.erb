<div class="mx-auto max-w-7xl px-4 py-10"><h1 class="text-3xl font-black">عمليات التجهيز والتوصيل</h1><%= form_with url: staff_fulfilments_path, method: :get, class: "mt-6 flex gap-3" do |f| %><%= f.select :status, Fulfilment.statuses.keys.map { |s| [s.humanize, s] }, { include_blank: "كل الحالات", selected: params[:status] }, class: "rounded-xl border px-4 py-3" %><%= f.submit "تصفية", class: "rounded-xl bg-pharmacy-700 px-5 font-bold text-white" %><% end %><div class="mt-6 grid gap-4"><% @fulfilments.each do |fulfilment| %><article class="rounded-2xl bg-white p-5 shadow-sm sm:flex sm:items-center sm:justify-between"><div><%= link_to fulfilment.order.number, staff_fulfilment_path(fulfilment), class: "text-lg font-black text-pharmacy-800" %><p class="mt-1 text-sm text-slate-500"><%= fulfilment.delivery_zone.name %> · <%= fulfilment.assigned_to&.full_name || "غير مسند" %></p></div><span class="mt-3 inline-block rounded-full bg-sky-100 px-3 py-1 text-sm font-bold sm:mt-0"><%= fulfilment.status.humanize %></span></article><% end %></div><div class="mt-6"><%== @pagy.series_nav if @pagy.pages > 1 %></div></div>
