<% content_for :title, "مناطق التوصيل" %>
<div class="mx-auto max-w-7xl px-4 py-10"><div class="flex items-center justify-between gap-4"><div><h1 class="text-3xl font-black">مناطق التوصيل</h1><p class="mt-2 text-slate-600">الرسوم والطرق والنطاقات التي يعتمدها الدفع.</p></div><%= link_to "منطقة جديدة", new_staff_delivery_zone_path, class: "rounded-xl bg-pharmacy-600 px-5 py-3 font-black text-white" %></div>
<div class="mt-8 grid gap-4 md:grid-cols-2"><% @delivery_zones.each do |zone| %><article class="rounded-2xl bg-white p-5 shadow-sm"><div class="flex justify-between"><div><h2 class="text-xl font-black"><%= link_to zone.name, staff_delivery_zone_path(zone) %></h2><p class="text-sm text-slate-500"><%= zone.governorate %> · <%= zone.city %> · <span dir="ltr"><%= zone.code %></span></p></div><span class="rounded-full px-3 py-1 text-xs font-bold <%= zone.active? ? 'bg-emerald-100 text-emerald-800' : 'bg-slate-200 text-slate-600' %>"><%= zone.active? ? "نشطة" : "متوقفة" %></span></div><dl class="mt-4 grid grid-cols-2 gap-3 text-sm"><div><dt class="text-slate-500">الرسوم</dt><dd class="font-black"><%= number_to_currency(zone.delivery_fee_cents / 100.0, unit: "ج.م", format: "%n %u") %></dd></div><div><dt class="text-slate-500">الأحياء</dt><dd class="font-black"><%= zone.districts.count(&:active?) %></dd></div></dl></article><% end %></div>
<div class="mt-6"><%== @pagy.series_nav if @pagy.pages > 1 %></div></div>
