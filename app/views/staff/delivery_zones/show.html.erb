<div class="mx-auto max-w-6xl px-4 py-10"><div class="flex justify-between gap-4"><div><h1 class="text-3xl font-black"><%= @delivery_zone.name %></h1><p class="mt-2 text-slate-500"><%= @delivery_zone.governorate %> · <%= @delivery_zone.city %></p></div><%= link_to "تعديل", edit_staff_delivery_zone_path(@delivery_zone), class: "rounded-xl border px-5 py-3 font-bold" %></div>
<section class="mt-7 rounded-3xl bg-white p-6"><h2 class="text-xl font-black">الأحياء</h2><p class="mt-3"><%= @delivery_zone.districts.active.pluck(:name).join("، ").presence || "كل أحياء المدينة" %></p></section>
<section class="mt-7 rounded-3xl bg-white p-6"><h2 class="text-xl font-black">المواعيد القادمة</h2><div class="mt-4 space-y-2"><% @delivery_zone.delivery_slots.order(:delivery_date, :starts_at).each do |slot| %><p class="rounded-xl border p-3"><%= l(slot.delivery_date) %> · <%= slot.starts_at.strftime("%H:%M") %>–<%= slot.ends_at.strftime("%H:%M") %> · <%= slot.remaining_capacity %> متاح</p><% end %></div><%= form_with model: [:staff, @delivery_zone, DeliverySlot.new], class: "mt-5 grid gap-3 sm:grid-cols-4" do |f| %><%= f.date_field :delivery_date, required: true, class: "rounded-xl border p-3" %><%= f.time_field :starts_at, required: true, class: "rounded-xl border p-3" %><%= f.time_field :ends_at, required: true, class: "rounded-xl border p-3" %><%= f.number_field :capacity, min: 1, value: 10, class: "rounded-xl border p-3" %><%= f.submit "إضافة موعد", class: "rounded-xl bg-pharmacy-600 p-3 font-black text-white" %><% end %></section></div>
