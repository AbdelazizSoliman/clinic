<%= form_with model: [:staff, delivery_zone], class: "mt-6 space-y-5" do |form| %><% if delivery_zone.errors.any? %><div class="rounded-xl bg-rose-50 p-4" role="alert"><ul><% delivery_zone.errors.full_messages.each do |message| %><li><%= message %></li><% end %></ul></div><% end %>
<div class="grid gap-4 sm:grid-cols-2"><% { name: "الاسم", code: "الكود", governorate: "المحافظة", city: "المدينة", delivery_fee_cents: "رسوم التوصيل بالقرش", free_delivery_threshold_cents: "حد التوصيل المجاني بالقرش", minimum_order_cents: "الحد الأدنى للطلب بالقرش", estimated_min_minutes: "أقل مدة بالدقائق", estimated_max_minutes: "أقصى مدة بالدقائق", position: "الترتيب" }.each do |field, label| %><div><%= form.label field, label, class: "mb-2 block font-bold" %><%= form.text_field field, class: "w-full rounded-xl border px-4 py-3" %></div><% end %></div>
<div><%= label_tag :districts, "الأحياء (افصل بفاصلة)", class: "mb-2 block font-bold" %><%= text_field_tag :districts, delivery_zone.districts.map(&:name).join("، "), class: "w-full rounded-xl border px-4 py-3" %></div>
<div class="flex flex-wrap gap-5"><% %i[active same_day_available scheduled_delivery_available cash_on_delivery_available].each do |field| %><label class="flex items-center gap-2"><%= form.check_box field %><span><%= field == :active ? "نشطة" : field.to_s.humanize %></span></label><% end %></div><%= form.submit class: "rounded-xl bg-pharmacy-600 px-6 py-3 font-black text-white" %><% end %>
