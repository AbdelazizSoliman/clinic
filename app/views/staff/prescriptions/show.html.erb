<% content_for :title, "مراجعة #{@prescription.order.number}" %><div class="mx-auto max-w-6xl px-4 py-10"><%= link_to "← قائمة الروشتات", staff_prescriptions_path, class: "font-bold text-pharmacy-700" %><h1 class="mt-5 text-3xl font-black">مراجعة روشتة الطلب <%= @prescription.order.number %></h1><div class="mt-6 grid gap-6 lg:grid-cols-2"><section class="rounded-2xl bg-white p-5"><h2 class="text-xl font-black">الملفات المرفوعة</h2><div class="mt-4 grid gap-3"><% @prescription.images.each do |image| %><%= link_to image.filename.to_s, staff_prescription_file_path(@prescription, image.id), target: "_blank", rel: "noopener", class: "rounded-xl border p-4 font-bold" %><% end %></div><h2 class="mt-6 font-black">المنتجات المعنية</h2><ul class="mt-2"><% @prescription.order.items.select(&:requires_prescription?).each do |item| %><li><%= item.product_name %> × <%= item.quantity %></li><% end %></ul></section><section class="rounded-2xl bg-white p-5"><h2 class="text-xl font-black">قرار المراجعة</h2><p class="mt-2">الحالة: <%= t("staff.prescription_statuses.#{@prescription.status}") %></p><% if @prescription.submitted? || @prescription.under_review? %><%= form_with url: review_staff_prescription_path(@prescription), method: :patch, class: "mt-5 grid gap-4" do |form| %><%= hidden_field_tag :lock_version, @prescription.lock_version %><%= label_tag :customer_message, "رسالة للعميل" %><%= text_area_tag :customer_message, nil, rows: 3, class: "rounded-xl border p-3" %><%= label_tag :internal_notes, "ملاحظات داخلية" %><%= text_area_tag :internal_notes, nil, rows: 3, class: "rounded-xl border p-3" %><div class="grid gap-2 sm:grid-cols-2"><% [["under_review", "بدء المراجعة"], ["approved", "اعتماد"], ["partially_approved", "اعتماد جزئي"], ["rejected", "رفض"]].each do |value, label| %><button name="decision" value="<%= value %>" class="rounded-xl border px-4 py-3 font-bold"><%= label %></button><% end %></div><% end %><% else %><div class="mt-5 rounded-xl bg-slate-100 p-4">تم اتخاذ قرار نهائي ولا يمكن تغييره دون مسار إعادة فتح مستقبلي.</div><% end %></section></div></div>
