<section class="mx-auto mt-6 max-w-6xl rounded-2xl bg-white p-5"><h2 class="text-xl font-black">فتح متابعة</h2><%= form_with url: staff_follow_ups_path, method: :post, class: "mt-4 grid gap-3 sm:grid-cols-2" do %><%= hidden_field_tag :order_number, order.number %><%= select_tag :kind, options_for_select(OrderFollowUp.kinds.keys), class: "rounded-xl border p-3" %><%= text_field_tag :subject, nil, required: true, placeholder: "موضوع المتابعة", class: "rounded-xl border p-3" %><%= text_area_tag :customer_message, nil, required: true, placeholder: "رسالة ظاهرة للعميل", class: "rounded-xl border p-3 sm:col-span-2" %><%= submit_tag "فتح متابعة", class: "rounded-xl bg-pharmacy-700 p-3 font-bold text-white" %><% end %></section>
<% if current_user.can_operate_orders? && order.staff_cancellable? %><section class="mx-auto mt-6 max-w-6xl rounded-2xl border border-rose-200 bg-white p-5"><h2 class="font-black">إلغاء تشغيلي</h2><%= form_with url: cancel_staff_order_path(order), method: :patch, class: "mt-3 flex gap-3", data: { turbo_confirm: "سيتم تحرير الحجوزات. متابعة؟" } do %><%= hidden_field_tag :lock_version, order.lock_version %><%= text_field_tag :reason, nil, required: true, placeholder: "سبب الإلغاء", class: "flex-1 rounded-xl border p-3" %><%= submit_tag "إلغاء", class: "rounded-xl bg-rose-700 px-5 text-white" %><% end %></section><% end %>
<% if current_user.admin? && order.inventory_reservations.active.exists? %><section class="mx-auto mt-6 max-w-6xl rounded-2xl bg-white p-5"><h2 class="font-black">استثناء إداري محدود</h2><%= form_with url: extend_reservations_staff_order_path(order), method: :patch, class: "mt-3 flex gap-3" do %><%= text_field_tag :reason, nil, required: true, placeholder: "سبب تمديد الحجز", class: "flex-1 rounded-xl border p-3" %><%= submit_tag "تمديد وفق السياسة", class: "rounded-xl border px-5" %><% end %></section><% end %>
