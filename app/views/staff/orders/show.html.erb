<% content_for :title, "تشغيل #{@order.number}" %><div class="mx-auto max-w-6xl px-4 py-10"><%= link_to "← قائمة الطلبات", staff_orders_path, class: "font-bold text-pharmacy-700" %><header class="mt-5 rounded-3xl bg-white p-6 shadow-sm"><div class="flex flex-wrap justify-between gap-4"><div><h1 class="text-3xl font-black"><%= @order.number %></h1><p class="mt-2"><%= @order.customer_first_name %> <%= @order.customer_last_name %> · <span dir="ltr"><%= @order.customer_mobile_number %></span></p></div><span class="rounded-full bg-pharmacy-100 px-4 py-2 font-black"><%= order_status_label(@order) %></span></div></header><div class="mt-6 grid gap-6 lg:grid-cols-2"><section class="rounded-2xl bg-white p-5"><h2 class="text-xl font-black">المنتجات والحجوزات</h2><% @order.items.each do |item| %><div class="mt-4 border-t pt-4"><strong><%= item.product_name %> × <%= item.quantity %></strong><p class="text-sm text-slate-500">الحجز: <%= item.inventory_reservation.status %> · المخزون الفعلي: <%= item.product&.stock_quantity %> · المتاح للبيع: <%= item.product&.available_to_sell_quantity %></p></div><% end %></section><section class="rounded-2xl bg-white p-5"><h2 class="text-xl font-black">الإجراءات المتاحة</h2><% if current_user.can_operate_orders? %><div class="mt-4 grid gap-3"><% Orders::Transition::RULES.fetch(@order.status, []).each do |target| %><%= button_to I18n.t("staff.transitions.#{target}"), transition_staff_order_path(@order), method: :patch, params: { to_status: target, lock_version: @order.lock_version }, form: { data: { turbo_confirm: "تأكيد تنفيذ هذا الإجراء؟" } }, class: "w-full rounded-xl bg-pharmacy-700 px-4 py-3 font-bold text-white" %><% end %></div><% end %><% if @order.prescription && current_user.can_review_prescriptions? %><%= link_to "مراجعة الروشتة", staff_prescription_path(@order.prescription), class: "mt-4 inline-block font-black text-amber-700" %><% end %></section></div><section class="mt-6 rounded-2xl bg-white p-5"><h2 class="text-xl font-black">سجل العمليات</h2><ol class="mt-4 space-y-3"><% @order.events.order(:created_at).each do |event| %><li class="border-r-2 border-pharmacy-300 pr-4"><strong><%= t("staff.events.#{event.event_type}") %></strong><small class="block text-slate-500"><%= l(event.created_at, format: :short) %></small></li><% end %></ol></section></div>
