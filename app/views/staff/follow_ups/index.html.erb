<% content_for :title, "متابعات العملاء" %><div class="mx-auto max-w-7xl px-4 py-10"><h1 class="text-3xl font-black">متابعات العملاء</h1><%= form_with url: staff_follow_ups_path, method: :get, class: "mt-6 grid gap-3 rounded-2xl bg-white p-4 sm:grid-cols-4" do |form| %><%= form.search_field :q, value: params[:q], placeholder: "الطلب أو العميل", aria: { label: "بحث" }, class: "rounded-xl border p-2" %><%= form.select :status, options_for_select([["كل الحالات", ""]] + OrderFollowUp.statuses.keys.map { |s| [s, s] }, params[:status]), {}, class: "rounded-xl border p-2" %><%= form.select :kind, options_for_select([["كل الأنواع", ""]] + OrderFollowUp.kinds.keys.map { |k| [k, k] }, params[:kind]), {}, class: "rounded-xl border p-2" %><%= form.submit "تطبيق", class: "rounded-xl bg-pharmacy-700 p-2 font-bold text-white" %><% end %><p class="mt-4"><%= @pagy.count %> متابعة</p><div class="mt-4 grid gap-4"><% @follow_ups.each do |follow_up| %><article class="rounded-2xl bg-white p-5"><div class="flex flex-wrap justify-between gap-3"><div><strong><%= link_to follow_up.order.number, staff_order_path(follow_up.order), class: "text-pharmacy-700" %></strong><h2 class="mt-1 font-black"><%= follow_up.subject %></h2><p class="text-sm text-slate-500"><%= follow_up.status %> · <%= follow_up.kind %></p></div><% if follow_up.customer_responded? %><%= button_to "حل المتابعة", resolve_staff_follow_up_path(follow_up), method: :patch, params: { lock_version: follow_up.lock_version }, class: "rounded-xl bg-pharmacy-700 px-4 py-2 font-bold text-white" %><% end %></div></article><% end %></div><% if @follow_ups.empty? %><p class="mt-6 rounded-2xl bg-white p-8 text-center">لا توجد متابعات مطابقة.</p><% end %></div>
