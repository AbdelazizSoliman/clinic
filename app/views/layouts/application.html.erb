<!DOCTYPE html>
<html lang="ar" dir="rtl">
  <head>
    <title><%= content_for(:title) || "صيدليتي | كل ما تحتاجه لصحتك" %></title>
    <meta name="description" content="صيدلية إلكترونية موثوقة للعناية بصحتك وصحة عائلتك">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased" data-controller="browser-cart-migration<%= " wishlist-migration" if user_signed_in? %>">
    <%= render "shared/demo_banner" %>
    <%= render "shared/header" %>
    <%= render "shared/flash" %>
    <main>
      <%= yield %>
      <%= render "orders/follow_ups_and_cancellation", order: @order if controller_name == "orders" && action_name == "show" && @order %>
      <%= render "account/phase8_summary" if controller_name == "account" && action_name == "show" %>
    </main>
    <%= render "shared/footer" %>
    <%= render "shared/toast_container" %>
  </body>
</html>
