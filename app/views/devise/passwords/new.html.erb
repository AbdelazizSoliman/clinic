<% content_for :title, "استعادة كلمة المرور | صيدليتي" %><div class="mx-auto max-w-md px-4 py-14"><div class="rounded-3xl bg-white p-7 shadow-sm"><h1 class="text-2xl font-black">استعادة كلمة المرور</h1><p class="mt-2 text-sm text-slate-600">سنرسل تعليمات إعادة التعيين إلى بريدك.</p><%= render "shared/form_errors", resource: resource %><%= form_with model: resource, as: resource_name, url: password_path(resource_name), method: :post, class: "mt-6 space-y-4" do |form| %><div><%= form.label :email, "البريد الإلكتروني", class: "mb-2 block text-sm font-bold" %><%= form.email_field :email, autofocus: true, required: true, class: "w-full rounded-xl border border-slate-300 px-4 py-3", dir: "ltr" %></div><%= form.submit "إرسال تعليمات الاستعادة", class: "w-full cursor-pointer rounded-xl bg-pharmacy-600 px-5 py-3 font-black text-white" %><% end %></div></div>
