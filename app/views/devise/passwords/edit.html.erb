<% content_for :title, "تعيين كلمة مرور جديدة | صيدليتي" %><div class="mx-auto max-w-md px-4 py-14"><div class="rounded-3xl bg-white p-7 shadow-sm"><h1 class="text-2xl font-black">كلمة مرور جديدة</h1><%= render "shared/form_errors", resource: resource %><%= form_with model: resource, as: resource_name, url: password_path(resource_name), method: :put, class: "mt-6 space-y-4" do |form| %><%= form.hidden_field :reset_password_token %><div><%= form.label :password, "كلمة المرور الجديدة", class: "mb-2 block text-sm font-bold" %><%= form.password_field :password, required: true, autocomplete: "new-password", class: "w-full rounded-xl border border-slate-300 px-4 py-3" %></div><div><%= form.label :password_confirmation, "تأكيد كلمة المرور", class: "mb-2 block text-sm font-bold" %><%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", class: "w-full rounded-xl border border-slate-300 px-4 py-3" %></div><%= form.submit "حفظ كلمة المرور", class: "w-full cursor-pointer rounded-xl bg-pharmacy-600 px-5 py-3 font-black text-white" %><% end %></div></div>
