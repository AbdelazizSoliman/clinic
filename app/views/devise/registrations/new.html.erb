<% content_for :title, "إنشاء حساب | صيدليتي" %><div class="mx-auto max-w-xl px-4 py-14"><div class="rounded-3xl bg-white p-7 shadow-sm"><h1 class="text-3xl font-black">إنشاء حساب جديد</h1><p class="mt-2 text-sm text-slate-600">بيانات بسيطة لحفظ سلتك وتجهيز تجربة حسابك.</p><%= render "shared/form_errors", resource: resource %><%= form_with model: resource, as: resource_name, url: registration_path(resource_name), class: "mt-7 grid gap-4 sm:grid-cols-2" do |form| %><div><%= form.label :first_name, "الاسم الأول", class: "mb-2 block text-sm font-bold" %><%= form.text_field :first_name, required: true, autocomplete: "given-name", class: "w-full rounded-xl border border-slate-300 px-4 py-3" %></div><div><%= form.label :last_name, "اسم العائلة", class: "mb-2 block text-sm font-bold" %><%= form.text_field :last_name, required: true, autocomplete: "family-name", class: "w-full rounded-xl border border-slate-300 px-4 py-3" %></div><div class="sm:col-span-2"><%= form.label :mobile_number, "رقم الموبايل", class: "mb-2 block text-sm font-bold" %><%= form.telephone_field :mobile_number, required: true, autocomplete: "tel", class: "w-full rounded-xl border border-slate-300 px-4 py-3", dir: "ltr" %></div><div class="sm:col-span-2"><%= form.label :email, "البريد الإلكتروني", class: "mb-2 block text-sm font-bold" %><%= form.email_field :email, required: true, autocomplete: "email", class: "w-full rounded-xl border border-slate-300 px-4 py-3", dir: "ltr" %></div><div><%= form.label :password, "كلمة المرور (8 أحرف على الأقل)", class: "mb-2 block text-sm font-bold" %><%= form.password_field :password, required: true, autocomplete: "new-password", class: "w-full rounded-xl border border-slate-300 px-4 py-3", dir: "ltr" %></div><div><%= form.label :password_confirmation, "تأكيد كلمة المرور", class: "mb-2 block text-sm font-bold" %><%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", class: "w-full rounded-xl border border-slate-300 px-4 py-3", dir: "ltr" %></div><div class="sm:col-span-2"><%= form.submit "إنشاء حساب", class: "w-full cursor-pointer rounded-xl bg-pharmacy-600 px-5 py-3 font-black text-white" %></div><% end %><p class="mt-5 text-center text-sm"><%= link_to "لديك حساب؟ سجل الدخول", new_session_path(resource_name), class: "font-bold text-pharmacy-700" %></p></div></div>
