<% content_for :title, "تسجيل الدخول | صيدليتي" %>
<div class="mx-auto max-w-md px-4 py-14">
  <div class="rounded-3xl bg-white p-7 shadow-sm">
    <h1 class="text-3xl font-black">تسجيل الدخول</h1>
    <p class="mt-2 text-sm text-slate-600">ادخل لحفظ سلتك والوصول إلى حسابك.</p>
    <%= render "shared/demo_hint", title: "الدخول إلى العرض", body: "يعطيك مشغّل العرض بريد الحساب وكلمة المرور بصورة خاصة. الحسابات ذات الصلاحيات التشغيلية تكمل التحقق برمز TOTP حالي، ولا تُعرض كلمات المرور أو أسرار TOTP هنا." %>
    <%= form_with model: resource, as: resource_name, url: session_path(resource_name), class: "mt-7 space-y-4" do |form| %>
      <div>
        <%= form.label :email, "البريد الإلكتروني", class: "mb-2 block text-sm font-bold" %>
        <%= form.email_field :email, autofocus: true, autocomplete: "email", required: true, class: "w-full rounded-xl border border-slate-300 px-4 py-3", dir: "ltr" %>
      </div>
      <div>
        <%= form.label :password, "كلمة المرور", class: "mb-2 block text-sm font-bold" %>
        <%= form.password_field :password, autocomplete: "current-password", required: true, class: "w-full rounded-xl border border-slate-300 px-4 py-3", dir: "ltr" %>
      </div>
      <% if devise_mapping.rememberable? %>
        <label class="flex items-center gap-2 text-sm"><%= form.check_box :remember_me %><span>تذكرني</span></label>
      <% end %>
      <%= form.submit "دخول", class: "w-full cursor-pointer rounded-xl bg-pharmacy-600 px-5 py-3 font-black text-white" %>
    <% end %>
    <div class="mt-5 flex justify-between text-sm font-bold">
      <%= link_to "إنشاء حساب", new_registration_path(resource_name), class: "text-pharmacy-700" %>
      <%= link_to "نسيت كلمة المرور؟", new_password_path(resource_name), class: "text-slate-600" %>
    </div>
  </div>
</div>
