<section class="mx-auto mb-12 mt-8 max-w-5xl px-4"><h2 class="text-2xl font-black">تحتاج انتباهك</h2><div class="mt-4 grid gap-4 sm:grid-cols-2"><%= link_to notifications_path, class: "rounded-2xl bg-white p-5 shadow-sm" do %><strong class="text-2xl"><%= @unread_notifications_count %></strong><span class="mr-2">إشعار غير مقروء</span><% end %><div class="rounded-2xl bg-white p-5 shadow-sm"><strong class="text-2xl"><%= @awaiting_follow_ups.count %></strong><span class="mr-2">متابعة تنتظر ردك</span><div class="mt-3 grid gap-2"><% @awaiting_follow_ups.limit(3).each do |follow_up| %><%= link_to follow_up.order.number, order_path(follow_up.order), class: "font-bold text-pharmacy-700" %><% end %></div></div></div></section>
