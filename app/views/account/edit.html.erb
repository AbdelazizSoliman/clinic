<% content_for :title, "تعديل الحساب | صيدليتي" %><div class="mx-auto max-w-xl px-4 py-12"><h1 class="text-3xl font-black">تعديل بيانات الحساب</h1><p class="mt-2 text-sm text-slate-600">تغيير البريد الإلكتروني يتطلب كلمة المرور الحالية.</p><%= render "shared/form_errors", resource: current_user %><%= form_with model: current_user, url: account_path, class: "mt-7 space-y-4" do |form| %><div class="grid gap-4 sm:grid-cols-2"><div><%= form.label :first_name, "الاسم الأول", class: "mb-2 block text-sm font-bold" %><%= form.text_field :first_name, class: "w-full rounded-xl border border-slate-300 px-4 py-3" %></div><div><%= form.label :last_name, "اسم العائلة", class: "mb-2 block text-sm font-bold" %><%= form.text_field :last_name, class: "w-full rounded-xl border border-slate-300 px-4 py-3" %></div></div><div><%= form.label :mobile_number, "رقم الموبايل", class: "mb-2 block text-sm font-bold" %><%= form.telephone_field :mobile_number, class: "w-full rounded-xl border border-slate-300 px-4 py-3", dir: "ltr" %></div><div><%= form.label :email, "البريد الإلكتروني", class: "mb-2 block text-sm font-bold" %><%= form.email_field :email, class: "w-full rounded-xl border border-slate-300 px-4 py-3", dir: "ltr" %></div><div><%= form.label :current_password, "كلمة المرور الحالية عند تغيير البريد", class: "mb-2 block text-sm font-bold" %><%= form.password_field :current_password, autocomplete: "current-password", class: "w-full rounded-xl border border-slate-300 px-4 py-3" %></div><%= form.submit "حفظ التغييرات", class: "w-full cursor-pointer rounded-xl bg-pharmacy-600 px-5 py-3 font-black text-white" %><% end %></div>
