<% content_for :title, "حسابي | صيدليتي" %><div class="mx-auto max-w-5xl px-4 py-12"><nav aria-label="مسار التنقل" class="text-sm text-slate-500"><%= link_to "الرئيسية", root_path %> / <span>حسابي</span></nav><header class="mt-6 rounded-3xl bg-pharmacy-900 p-8 text-white"><p class="text-emerald-200">مرحبًا بك</p><h1 class="mt-2 text-3xl font-black"><%= current_user.full_name %></h1><p class="mt-2 text-emerald-100"><span dir="ltr"><%= current_user.email %></span> · <span dir="ltr"><%= current_user.mobile_number %></span></p></header><div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4"><%= link_to edit_account_path, class: "rounded-2xl bg-white p-5 shadow-sm" do %><span class="text-2xl">👤</span><h2 class="mt-3 font-black">بيانات الحساب</h2><p class="mt-1 text-sm text-slate-500">تعديل الاسم والموبايل والبريد</p><% end %><%= link_to account_addresses_path, class: "rounded-2xl bg-white p-5 shadow-sm" do %><span class="text-2xl">📍</span><h2 class="mt-3 font-black">عناويني (<%= @addresses.count %>)</h2><p class="mt-1 text-sm text-slate-500"><%= @default_address ? @default_address.summary : "أضف عنوان التوصيل الأول" %></p><% end %><%= link_to wishlist_path, class: "rounded-2xl bg-white p-5 shadow-sm" do %><span class="text-2xl">♥</span><h2 class="mt-3 font-black">المفضلة (<%= current_user.wishlist_items.count %>)</h2><p class="mt-1 text-sm text-slate-500">منتجات محفوظة في حسابك</p><% end %><%= link_to orders_path, class: "rounded-2xl bg-white p-5 shadow-sm" do %><span class="text-2xl">📦</span><h2 class="mt-3 font-black">طلباتي (<%= current_user.orders.count %>)</h2><p class="mt-1 text-sm text-slate-500"><%= current_user.orders.pending_prescription.count %> بانتظار الروشتة</p><% end %><div aria-disabled="true" class="rounded-2xl bg-white p-5 opacity-60 shadow-sm"><span class="text-2xl">⚕</span><h2 class="mt-3 font-black">الروشتات</h2><p class="mt-1 text-sm text-slate-500">إدارة مستقلة ستتوفر لاحقًا</p></div></div><% if @recent_orders.any? %><section class="mt-10"><h2 class="text-2xl font-black">أحدث الطلبات</h2><div class="mt-4 grid gap-3"><% @recent_orders.each do |order| %><%= link_to order_path(order), class: "flex justify-between rounded-xl bg-white p-4 shadow-sm" do %><strong><%= order.number %></strong><span><%= order_status_label(order) %></span><% end %><% end %></div></section><% end %></div>
