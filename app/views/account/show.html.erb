<% content_for :title, "حسابي | صيدليتي" %><div class="mx-auto max-w-5xl px-4 py-12"><nav aria-label="مسار التنقل" class="text-sm text-slate-500"><%= link_to "الرئيسية", root_path %> / <span>حسابي</span></nav><header class="mt-6 rounded-3xl bg-pharmacy-900 p-8 text-white"><p class="text-emerald-200">مرحبًا بك</p><h1 class="mt-2 text-3xl font-black"><%= current_user.full_name %></h1><p class="mt-2 text-emerald-100" dir="ltr"><%= current_user.email %></p></header><div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4"><%= link_to edit_account_path, class: "rounded-2xl bg-white p-5 shadow-sm" do %><span class="text-2xl">👤</span><h2 class="mt-3 font-black">بيانات الحساب</h2><p class="mt-1 text-sm text-slate-500">تعديل الاسم والموبايل والبريد</p><% end %><% [["📦", "طلباتي", "ستتوفر في مرحلة لاحقة"], ["📍", "عناويني", "ستتوفر في مرحلة لاحقة"], ["⚕", "الروشتات", "ستتوفر في مرحلة لاحقة"]].each do |icon, title, text| %><div class="rounded-2xl bg-white p-5 opacity-70 shadow-sm"><span class="text-2xl"><%= icon %></span><h2 class="mt-3 font-black"><%= title %></h2><p class="mt-1 text-sm text-slate-500"><%= text %></p></div><% end %></div></div>
