<% content_for :title, "عناويني | صيدليتي" %>
<div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
  <nav aria-label="مسار التنقل" class="text-sm text-slate-500"><%= link_to "الرئيسية", root_path %> / <%= link_to "حسابي", account_path %> / <span>العناوين</span></nav>
  <header class="mt-6 flex flex-wrap items-end justify-between gap-4"><div><h1 class="text-3xl font-black">عناوين التوصيل</h1><p class="mt-2 text-slate-600">أدر عناوينك واختر العنوان الافتراضي للطلبات القادمة.</p></div><%= link_to "إضافة عنوان جديد", new_account_address_path, class: "rounded-xl bg-pharmacy-600 px-5 py-3 font-black text-white" %></header>
  <% if @addresses.empty? %><section class="mt-10 rounded-3xl border border-dashed border-slate-300 bg-white p-12 text-center"><div class="text-5xl">📍</div><h2 class="mt-4 text-2xl font-black">لا توجد عناوين محفوظة</h2><p class="mt-2 text-slate-500">أضف عنوانًا لتسريع خطوة التوصيل.</p></section><% else %>
    <div class="mt-8 grid gap-5 md:grid-cols-2"><% @addresses.each do |address| %><article class="rounded-2xl border bg-white p-6 shadow-sm <%= address.default? && address.active? ? "border-pharmacy-400" : "border-slate-200" %>"><div class="flex items-start justify-between gap-3"><div><h2 class="text-lg font-black"><%= address.label %></h2><p class="mt-1 text-sm text-slate-600"><%= address.recipient_name %> · <span dir="ltr"><%= address.mobile_number %></span></p></div><div class="flex gap-2"><% if address.default? && address.active? %><span class="rounded-full bg-pharmacy-100 px-3 py-1 text-xs font-black text-pharmacy-800">افتراضي</span><% end %><span class="rounded-full px-3 py-1 text-xs font-bold <%= address.active? ? "bg-emerald-100 text-emerald-800" : "bg-slate-100 text-slate-500" %>"><%= address.active? ? "نشط" : "غير نشط" %></span></div></div><address class="mt-4 not-italic leading-7 text-slate-700"><%= address.summary %></address><% if address.landmark.present? %><p class="mt-2 text-sm text-slate-500">علامة مميزة: <%= address.landmark %></p><% end %><div class="mt-5 flex flex-wrap gap-3 border-t pt-4"><%= link_to "تعديل", edit_account_address_path(address), class: "font-bold text-pharmacy-700" %><% if address.active? && !address.default? %><%= button_to "تعيين افتراضي", set_default_account_address_path(address), method: :patch, class: "font-bold text-pharmacy-700" %><% end %><% if address.active? %><%= button_to "تعطيل", deactivate_account_address_path(address), method: :patch, form: { data: { turbo_confirm: "هل تريد تعطيل هذا العنوان؟" } }, class: "font-bold text-rose-600" %><% end %></div></article><% end %></div>
  <% end %>
</div>
