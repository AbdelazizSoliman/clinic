<%= render "shared/form_errors", resource: address %>
<%= form_with model: [ :account, address ], class: "mt-7 grid gap-5 sm:grid-cols-2", data: { turbo_frame: "_top" } do |form| %>
  <% fields = [[:label, "اسم العنوان *", "المنزل"], [:recipient_name, "اسم المستلم *", "أحمد محمد"], [:mobile_number, "رقم الموبايل *", "01012345678"], [:governorate, "المحافظة *", "القاهرة"], [:city, "المدينة *", "مدينة نصر"], [:district, "الحي", "المنطقة السادسة"], [:street, "الشارع *", "شارع مصطفى النحاس"], [:building_number, "رقم المبنى *", "25"], [:floor, "الدور", "3"], [:apartment, "الشقة", "8"], [:landmark, "علامة مميزة", "بجوار الصيدلية"], [:postal_code, "الرمز البريدي", "11765"]] %>
  <% fields.each do |field, label, placeholder| %><div class="<%= "sm:col-span-2" if %i[street landmark].include?(field) %>"><%= form.label field, label, class: "mb-2 block text-sm font-bold" %><%= form.text_field field, required: label.include?("*"), placeholder:, dir: field == :mobile_number ? "ltr" : nil, class: "w-full rounded-xl border border-slate-300 px-4 py-3 focus:border-pharmacy-500" %><% address.errors[field].each do |error| %><p class="mt-1 text-sm text-rose-600"><%= error %></p><% end %></div><% end %>
  <div class="sm:col-span-2"><%= form.label :delivery_notes, "ملاحظات التوصيل", class: "mb-2 block text-sm font-bold" %><%= form.text_area :delivery_notes, rows: 3, placeholder: "تعليمات مفيدة للمندوب دون بيانات حساسة", class: "w-full rounded-xl border border-slate-300 px-4 py-3" %></div>
  <label class="sm:col-span-2 flex items-center gap-3 rounded-xl bg-pharmacy-50 p-4 font-bold"><%= form.check_box :default, class: "size-5" %> اجعل هذا عنواني الافتراضي</label>
  <div class="sm:col-span-2 flex gap-3"><%= form.submit address.persisted? ? "حفظ التعديلات" : "حفظ العنوان", class: "cursor-pointer rounded-xl bg-pharmacy-600 px-6 py-3 font-black text-white" %><%= link_to "إلغاء", account_addresses_path, class: "rounded-xl border px-6 py-3 font-bold" %></div>
<% end %>
