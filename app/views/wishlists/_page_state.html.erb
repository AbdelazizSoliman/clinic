<div id="wishlist_page_state"><div class="flex items-end justify-between gap-3"><div><h1 class="text-3xl font-black">قائمة المفضلة</h1><p class="mt-2 text-slate-600"><%= current_user.wishlist_items.count %> منتج محفوظ في حسابك</p></div><% if current_user.wishlist_items.any? %><%= button_to "مسح المفضلة", clear_wishlist_path, method: :delete, form: { data: { turbo_confirm: "هل تريد مسح كل المنتجات من المفضلة؟" } }, class: "text-sm font-bold text-rose-600" %><% end %></div><% if current_user.wishlist_items.empty? %><div class="mt-10 rounded-3xl border border-dashed border-slate-300 bg-white p-12 text-center"><div class="text-6xl">♡</div><h2 class="mt-4 text-2xl font-black">لم تحفظ منتجات بعد</h2><%= link_to "اكتشف المنتجات", products_path, class: "mt-6 inline-block rounded-xl bg-pharmacy-600 px-6 py-3 font-black text-white" %></div><% else %><div class="mt-10 grid grid-cols-1 gap-5 min-[420px]:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"><% current_user.wishlist_items.includes(product: %i[brand category]).order(created_at: :desc).each do |item| %><%= render "products/product_card", product: item.product %><% end %></div><% end %></div>
