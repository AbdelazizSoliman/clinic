<%= form_with model:[:admin,brand],class:"grid gap-4 rounded-2xl bg-white p-6" do |f| %><%= f.hidden_field :lock_version %><%= f.label :name,"الاسم" %><%= f.text_field :name,required:true,class:"rounded-xl border p-3" %><%= f.label :slug,"الرابط المختصر" %><%= f.text_field :slug,required:true,class:"rounded-xl border p-3",dir:"ltr" %><%= f.label :description,"الوصف" %><%= f.text_area :description,class:"rounded-xl border p-3" %><%= f.label :website_url,"الموقع" %><%= f.url_field :website_url,class:"rounded-xl border p-3",dir:"ltr" %><%= f.label :logo,"الشعار" %><%= f.file_field :logo,accept:"image/jpeg,image/png,image/webp" %><%= f.label :active do %><%= f.check_box :active %> نشطة<% end %><%= f.submit "حفظ",class:"rounded-xl bg-pharmacy-700 p-3 text-white" %><% end %>
