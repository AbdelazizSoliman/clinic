<div class="mx-auto max-w-5xl px-4 py-10"><div class="flex justify-between"><h1 class="text-3xl font-black">العلامات التجارية</h1><%= link_to "علامة جديدة",new_admin_brand_path,class:"rounded-xl bg-pharmacy-700 px-4 py-3 text-white" %></div><div class="mt-6 grid gap-3"><% @brands.each do |brand| %><article class="flex justify-between rounded-2xl bg-white p-5"><div><strong><%= brand.name %></strong><p class="text-sm text-slate-500"><%= brand.products.count %> منتج · <%= brand.active? ? "نشطة" : "متوقفة" %></p></div><div class="flex gap-3"><%= link_to "تعديل",edit_admin_brand_path(brand) %><%= button_to "إيقاف",deactivate_admin_brand_path(brand),method: :patch if brand.active? %></div></article><% end %></div></div>
