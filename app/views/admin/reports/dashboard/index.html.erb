<div class="mx-auto max-w-7xl px-4 py-10"><h1 class="text-3xl font-black">لوحة التقارير التشغيلية</h1><p class="mt-2 text-slate-600">بطاقات حسب صلاحياتك، دون إعادة حساب التاريخ من بيانات المنتجات الحالية.</p><%= render "admin/reports/filters" %><div class="mt-7 grid gap-4 sm:grid-cols-2 lg:grid-cols-4"><% if @sales %><%= link_to admin_reports_sales_path(request.query_parameters), class: "rounded-2xl bg-white p-5 shadow-sm" do %><span class="text-sm text-slate-500">صافي قيمة الطلبات المحققة</span><strong class="mt-2 block text-2xl"><%= number_to_currency(@sales.cards[:net_cents] / 100.0, unit: "ج.م", format: "%n %u") %></strong><small><%= @sales.cards[:confirmed_orders] %> طلبًا</small><% end %><% end %><% if @inventory %><%= link_to admin_reports_inventory_index_path(request.query_parameters), class: "rounded-2xl bg-white p-5 shadow-sm" do %><span class="text-sm text-slate-500">متاح للبيع</span><strong class="mt-2 block text-2xl"><%= @inventory.cards[:available] %></strong><small><%= @inventory.cards[:low_stock] %> مخزون منخفض</small><% end %><% end %><% if @prescriptions %><%= link_to admin_reports_prescriptions_path(request.query_parameters), class: "rounded-2xl bg-white p-5 shadow-sm" do %><span class="text-sm text-slate-500">روشتات بانتظار المراجعة</span><strong class="mt-2 block text-2xl"><%= @prescriptions.status_counts.fetch("submitted", 0) %></strong><small>لا تعرض اللوحة ملفات أو تفاصيل طبية</small><% end %><% end %><% if @fulfilments %><%= link_to admin_reports_fulfilments_path(request.query_parameters), class: "rounded-2xl bg-white p-5 shadow-sm" do %><span class="text-sm text-slate-500">مهام غير مسندة</span><strong class="mt-2 block text-2xl"><%= @fulfilments.status_counts.fetch("unassigned", 0) %></strong><small>عمليات التوصيل</small><% end %><% end %></div></div>
