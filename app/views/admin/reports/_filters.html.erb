<%= form_with url: request.path, method: :get, class: "mt-6 rounded-2xl bg-white p-4 shadow-sm", role: "search" do |form| %><div class="grid gap-3 sm:grid-cols-4"><div><%= form.label :preset, "الفترة", class: "mb-1 block text-sm font-bold" %><%= form.select :preset, [["اليوم", "today"], ["أمس", "yesterday"], ["آخر 7 أيام", "last_7_days"], ["آخر 30 يومًا", "last_30_days"], ["الشهر الحالي", "current_month"], ["الشهر السابق", "previous_month"], ["الربع الحالي", "current_quarter"], ["السنة الحالية", "current_year"], ["مخصص", "custom"]], { selected: @date_range.preset }, class: "w-full rounded-xl border px-3 py-2" %></div><div><%= form.label :from, "من", class: "mb-1 block text-sm font-bold" %><%= form.date_field :from, value: params[:from], class: "w-full rounded-xl border px-3 py-2" %></div><div><%= form.label :to, "إلى", class: "mb-1 block text-sm font-bold" %><%= form.date_field :to, value: params[:to], class: "w-full rounded-xl border px-3 py-2" %></div><div class="flex items-end gap-2"><%= form.submit "تحديث", class: "rounded-xl bg-pharmacy-700 px-5 py-2 font-bold text-white" %><%= link_to "مسح", request.path, class: "rounded-xl border px-4 py-2 font-bold" %></div></div><% end %>
