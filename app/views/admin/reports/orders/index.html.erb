<div class="mx-auto max-w-7xl px-4 py-10"><div class="flex justify-between"><h1 class="text-3xl font-black">عمليات الطلبات</h1><%= render "admin/reports/export" %></div><%= render "admin/reports/filters" %><div class="mt-7 grid gap-4 sm:grid-cols-3"><% @report.status_counts.each do |status, count| %><div class="rounded-2xl bg-white p-5"><span><%= status %></span><strong class="block text-2xl"><%= count %></strong></div><% end %></div><section class="mt-7 rounded-2xl bg-white p-5"><h2 class="text-xl font-black">متوسط المدد</h2><div class="mt-4 grid gap-3 sm:grid-cols-3"><% @report.durations.each do |name, metric| %><div class="rounded-xl bg-slate-50 p-4"><strong><%= name %></strong><span class="block"><%= metric[:average_seconds] ? distance_of_time_in_words(metric[:average_seconds]) : "غير متاح" %></span><small><%= metric[:sample_count] %> عينة</small></div><% end %></div></section><section class="mt-7 rounded-2xl bg-white p-5"><h2 class="text-xl font-black">الأقدم بانتظار إجراء</h2><div class="mt-4 space-y-2"><% @report.oldest_actionable.each do |order| %><%= link_to order.number, staff_order_path(order), class: "block rounded-xl border p-3 font-bold" %><% end %></div></section></div>
