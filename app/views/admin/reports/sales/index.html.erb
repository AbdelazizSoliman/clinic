<div class="mx-auto max-w-7xl px-4 py-10"><div class="flex items-center justify-between gap-4"><div><h1 class="text-3xl font-black">تقرير المبيعات</h1><p class="mt-2 text-sm text-slate-600">القيمة المحققة تشمل المؤكد وما بعده؛ الطلبات المعلقة والإلغاءات معروضة منفصلة وليست نقدًا محصلًا.</p></div><%= render "admin/reports/export" %></div><%= render "admin/reports/filters" %><div class="mt-7 grid gap-4 sm:grid-cols-2 lg:grid-cols-4"><% { gross_cents: "إجمالي خام", discount_cents: "خصومات مقبولة", delivery_cents: "إيراد التوصيل", net_cents: "صافي قيمة الطلب", average_cents: "متوسط الطلب", pipeline_cents: "قيمة قيد الانتظار", cancelled_cents: "ملغي", rejected_cents: "مرفوض" }.each do |key, label| %><div class="rounded-2xl bg-white p-5"><span class="text-sm text-slate-500"><%= label %></span><strong class="mt-2 block text-xl"><%= number_to_currency(@report.cards[key] / 100.0, unit: "ج.م", format: "%n %u") %></strong></div><% end %></div><section class="mt-7 rounded-2xl bg-white p-5"><h2 class="text-xl font-black">القيمة اليومية</h2><div class="mt-4 overflow-x-auto"><table class="w-full min-w-[36rem] text-right"><thead><tr><th>اليوم</th><th>الطلبات</th><th>الخام</th><th>الصافي</th></tr></thead><tbody><% @report.series.each do |date, count, gross, net| %><tr class="border-t"><td class="py-3"><%= date %></td><td><%= count %></td><td><%= gross %> قرش</td><td><%= net %> قرش</td></tr><% end %></tbody></table></div></section></div>
