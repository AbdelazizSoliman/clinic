<div class="mx-auto max-w-7xl px-4 py-10"><div class="flex justify-between"><div><h1 class="text-3xl font-black">مؤشرات مراجعة الروشتات</h1><p class="mt-2 text-sm text-slate-600">بيانات سير العمل فقط؛ لا ملفات ولا ملاحظات طبية في الصفحة أو التصدير.</p></div><%= render "admin/reports/export" %></div><%= render "admin/reports/filters" %><div class="mt-7 grid gap-4 sm:grid-cols-3"><% @report.status_counts.each do |status, count| %><div class="rounded-2xl bg-white p-5"><span><%= status %></span><strong class="block text-2xl"><%= count %></strong></div><% end %><div class="rounded-2xl bg-white p-5">نسبة الاعتماد<strong class="block text-2xl"><%= @report.approval_rate ? "#{@report.approval_rate}%" : "غير متاح" %></strong></div><div class="rounded-2xl bg-white p-5">متوسط المراجعة<strong class="block text-xl"><%= @report.average_review_seconds ? distance_of_time_in_words(@report.average_review_seconds) : "غير متاح" %></strong><small><%= @report.review_sample_count %> عينة</small></div></div></div>
