<div class="mx-auto max-w-7xl px-4 py-10"><div class="flex justify-between"><div><h1 class="text-3xl font-black">أداء العروض والكوبونات</h1><p class="mt-2 text-sm text-slate-600">الاستخدام وليس معدل تحويل؛ لا يوجد سجل كامل لمرات مشاهدة أو تطبيق الحملات.</p></div><%= render "admin/reports/export" %></div><%= render "admin/reports/filters" %><div class="mt-7 grid gap-4 sm:grid-cols-4"><div class="rounded-2xl bg-white p-5">مستخدم<strong class="block text-2xl"><%= @report.redeemed_count %></strong></div><div class="rounded-2xl bg-white p-5">محرر<strong class="block text-2xl"><%= @report.released_count %></strong></div><div class="rounded-2xl bg-white p-5">الخصم<strong class="block text-2xl"><%= @report.discount_cents %> قرش</strong></div><div class="rounded-2xl bg-white p-5">طلبات الخصم<strong class="block text-2xl"><%= @report.orders %></strong></div></div><div class="mt-7 overflow-x-auto rounded-2xl bg-white p-4"><table class="w-full min-w-[44rem] text-right"><thead><tr><th>الحملة</th><th>الكود</th><th>الطلبات</th><th>الخصم</th><th>الخام</th><th>الصافي</th></tr></thead><tbody><% @report.rows.each do |row| %><tr class="border-t"><td class="py-3"><%= row.promotion_name %></td><td dir="ltr"><%= row.code.present? ? "••••#{row.code.last(4)}" : "تلقائي" %></td><td><%= row.orders_count %></td><td><%= row.discount_total_cents %></td><td><%= row.gross_cents %></td><td><%= row.net_cents %></td></tr><% end %></tbody></table></div></div>
