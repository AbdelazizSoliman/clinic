<div class="mx-auto max-w-7xl px-4 py-10"><div class="flex justify-between"><h1 class="text-3xl font-black">التجهيز والتوصيل</h1><%= render "admin/reports/export" %></div><%= render "admin/reports/filters" %><div class="mt-7 grid gap-4 sm:grid-cols-3"><% @report.status_counts.each do |status, count| %><div class="rounded-2xl bg-white p-5"><span><%= status %></span><strong class="block text-2xl"><%= count %></strong></div><% end %><div class="rounded-2xl bg-white p-5">متوسط الإسناد<strong class="block"><%= @report.average_assignment_seconds ? distance_of_time_in_words(@report.average_assignment_seconds) : "غير متاح" %></strong><small><%= @report.assignment_sample_count %> عينة</small></div><div class="rounded-2xl bg-white p-5">متوسط التوصيل<strong class="block"><%= @report.average_delivery_seconds ? distance_of_time_in_words(@report.average_delivery_seconds) : "غير متاح" %></strong><small><%= @report.delivery_sample_count %> عينة</small></div></div><section class="mt-7 rounded-2xl bg-white p-5"><h2 class="text-xl font-black">استغلال المواعيد</h2><div class="mt-3 space-y-2"><% @report.slots.each do |zone_id, capacity, booked| %><div class="flex justify-between rounded-xl bg-slate-50 p-3"><span>منطقة <%= zone_id %></span><span><%= capacity.to_i.zero? ? "غير متاح" : "#{(booked.to_f * 100 / capacity).round(1)}%" %> · <%= booked %>/<%= capacity %></span></div><% end %></div></section></div>
