<% content_for :title, "لوحة المخزون" %><div class="mx-auto max-w-7xl px-4 py-10"><h1 class="text-3xl font-black">لوحة المخزون والكتالوج</h1><div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4"><% [["المنتجات النشطة",@active_products],["نفد المخزون",@out_of_stock],["مخزون منخفض",@low_stock],["الوحدات الفعلية",@physical_units],["المحجوز",@reserved_units],["المتاح للبيع",@available_units]].each do |label,value| %><div class="rounded-2xl bg-white p-5 shadow-sm"><span class="text-sm text-slate-500"><%= label %></span><strong class="mt-2 block text-3xl"><%= value %></strong></div><% end %></div><div class="mt-8 grid gap-6 lg:grid-cols-2"><section class="rounded-2xl bg-white p-5"><h2 class="text-xl font-black">أحدث حركات المخزون</h2><ul class="mt-4 divide-y"><% @recent_movements.each do |movement| %><li class="py-3"><strong><%= movement.product.name %></strong> · <span dir="ltr"><%= movement.quantity_delta %></span> · <%= movement.reason %></li><% end %></ul></section><section class="rounded-2xl bg-white p-5"><h2 class="text-xl font-black">أحدث تغييرات الأسعار</h2><ul class="mt-4 divide-y"><% @recent_price_changes.each do |change| %><li class="py-3"><strong><%= change.product.name %></strong> · <%= change.old_price_cents/100.0 %> ← <%= change.new_price_cents/100.0 %> ج.م</li><% end %></ul></section></div></div>
