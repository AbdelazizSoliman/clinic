<div class="mx-auto max-w-6xl px-4 py-10"><h1 class="text-3xl font-black">المخزون المنخفض والنافد</h1><div class="mt-6 grid gap-4"><% @products.each do |product| %><%= link_to admin_product_path(product), class: "grid gap-2 rounded-2xl bg-white p-5 sm:grid-cols-4" do %><strong><%= product.name %></strong><span>فعلي: <%= product.stock_quantity %></span><span>محجوز: <%= product.active_reserved_quantity %></span><span class="font-bold <%= product.out_of_stock? ? 'text-rose-700' : 'text-amber-700' %>">متاح: <%= product.available_to_sell_quantity %></span><% end %><% end %></div><% if @products.empty? %><p class="mt-8 rounded-2xl bg-white p-10 text-center">لا توجد منتجات منخفضة المخزون.</p><% end %></div>
