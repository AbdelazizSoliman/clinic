<% if user.errors.any? %><div class="mb-5 rounded-xl bg-red-50 p-4 text-red-800" role="alert"><h2 class="font-bold">تعذر الحفظ</h2><ul><% user.errors.full_messages.each do |message| %><li><%= message %></li><% end %></ul></div><% end %><%= form_with model: [:admin, user], class: "grid gap-5 rounded-2xl bg-white p-6 sm:grid-cols-2" do |form| %><div><%= form.label :first_name, "الاسم الأول", class: "block font-bold" %><%= form.text_field :first_name, required: true, class: "mt-1 w-full rounded-xl border p-3" %></div><div><%= form.label :last_name, "اسم العائلة", class: "block font-bold" %><%= form.text_field :last_name, required: true, class: "mt-1 w-full rounded-xl border p-3" %></div><div><%= form.label :email, "البريد الإلكتروني", class: "block font-bold" %><%= form.email_field :email, required: true, class: "mt-1 w-full rounded-xl border p-3" %></div><div><%= form.label :mobile_number, "رقم الهاتف", class: "block font-bold" %><%= form.telephone_field :mobile_number, required: true, class: "mt-1 w-full rounded-xl border p-3" %></div><div><%= form.label :role, "الدور", class: "block font-bold" %><%= form.select :role, User.roles.keys.map { |role| [I18n.t("staff.roles.#{role}"), role] }, {}, class: "mt-1 w-full rounded-xl border p-3" %></div><% if user.persisted? %><div><%= label_tag :reason, "سبب التغيير", class: "block font-bold" %><%= text_field_tag :reason, nil, required: true, class: "mt-1 w-full rounded-xl border p-3" %></div><% end %><div class="sm:col-span-2"><%= form.submit user.persisted? ? "حفظ التعديلات" : "إنشاء وإرسال الدعوة", class: "rounded-xl bg-pharmacy-700 px-6 py-3 font-bold text-white" %></div><% end %>
