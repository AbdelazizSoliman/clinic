<div class="mx-auto max-w-5xl px-4 py-10"><div class="flex flex-wrap justify-between gap-4"><div><h1 class="text-3xl font-black"><%= @user.full_name %></h1><p class="text-slate-600"><%= @user.email %> · <%= @user.mobile_number %></p></div><%= link_to "تعديل", edit_admin_user_path(@user), class: "rounded-xl border px-5 py-3 font-bold" %></div><div class="mt-6 grid gap-4 sm:grid-cols-3"><div class="rounded-2xl bg-white p-5"><small>الدور</small><strong class="block"><%= I18n.t("staff.roles.#{@user.role}") %></strong></div><div class="rounded-2xl bg-white p-5"><small>الحالة</small><strong class="block"><%= @user.active? ? "نشط" : "غير نشط" %></strong></div><div class="rounded-2xl bg-white p-5"><small>الدخول</small><strong class="block"><%= @user.sign_in_count %> مرة</strong></div></div><div class="mt-6 flex flex-wrap gap-3"><% if @user.active? %><%= button_to "تعطيل", deactivate_admin_user_path(@user), method: :patch, params: { reason: "تعطيل إداري" }, form: { data: { turbo_confirm: "هل تريد تعطيل الحساب؟" } }, class: "rounded-xl bg-red-700 px-4 py-2 text-white" %><% else %><%= button_to "تفعيل", activate_admin_user_path(@user), method: :patch, params: { reason: "إعادة تفعيل إداري" }, class: "rounded-xl bg-emerald-700 px-4 py-2 text-white" %><%= button_to "إعادة إرسال الدعوة", resend_invitation_admin_user_path(@user), method: :patch, class: "rounded-xl border px-4 py-2" %><% end %><% if @user.access_locked? %><%= button_to "فتح الحساب", unlock_admin_user_path(@user), method: :patch, params: { reason: "فتح إداري" }, class: "rounded-xl border px-4 py-2" %><% end %></div><section class="mt-8 rounded-2xl bg-white p-6"><h2 class="text-xl font-black">سجل التدقيق</h2><div class="mt-4 space-y-3"><% @events.each do |event| %><article class="border-t pt-3"><strong><%= event.action %></strong><span class="text-sm text-slate-500"> — <%= event.created_at.in_time_zone("Africa/Cairo").strftime("%Y-%m-%d %H:%M") %></span><p><%= event.reason %></p></article><% end %></div></section></div>
