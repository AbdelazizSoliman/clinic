<div class="mx-auto max-w-7xl px-4 py-10"><div class="flex flex-wrap items-center justify-between gap-3"><div><h1 class="text-3xl font-black">إدارة المستخدمين</h1><p class="text-slate-600">الحسابات والأدوار وحالة الدعوات دون عرض كلمات المرور.</p></div><%= link_to "دعوة مستخدم", new_admin_user_path, class: "rounded-xl bg-pharmacy-700 px-5 py-3 font-bold text-white" %></div><%= form_with url: admin_users_path, method: :get, class: "mt-6 grid gap-3 rounded-2xl bg-white p-4 md:grid-cols-5" do |form| %><%= form.search_field :q, value: params[:q], placeholder: "الاسم أو البريد أو الهاتف", aria: { label: "بحث المستخدمين" }, class: "rounded-xl border p-3 md:col-span-2" %><%= form.select :role, User.roles.keys.map { |role| [I18n.t("staff.roles.#{role}"), role] }, { include_blank: "كل الأدوار", selected: params[:role] }, class: "rounded-xl border p-3" %><%= form.select :active, [["نشط", "true"], ["غير نشط", "false"]], { include_blank: "كل الحالات", selected: params[:active] }, class: "rounded-xl border p-3" %><%= form.submit "تطبيق", class: "rounded-xl bg-slate-900 p-3 font-bold text-white" %><% end %><div class="mt-6 overflow-x-auto rounded-2xl bg-white p-4"><table class="w-full min-w-[60rem] text-right"><thead><tr><th>المستخدم</th><th>الهاتف</th><th>الدور</th><th>الحالة</th><th>آخر دخول</th><th>الإنشاء</th><th></th></tr></thead><tbody><% @users.each do |user| %><tr class="border-t"><td class="py-4"><strong><%= user.full_name %></strong><small class="block text-slate-500"><%= user.email %></small></td><td><%= user.mobile_number %></td><td><%= I18n.t("staff.roles.#{user.role}") %></td><td><span class="rounded-full px-3 py-1 text-sm <%= user.active? ? 'bg-emerald-100 text-emerald-800' : 'bg-slate-200' %>"><%= user.active? ? "نشط" : "غير نشط/بانتظار الدعوة" %></span></td><td><%= user.last_sign_in_at&.in_time_zone("Africa/Cairo")&.strftime("%Y-%m-%d %H:%M") || "لم يدخل" %></td><td><%= user.created_at.to_date %></td><td><%= link_to "التفاصيل", admin_user_path(user), class: "font-bold text-pharmacy-700" %></td></tr><% end %></tbody></table></div><div class="mt-5"><%== @pagy.series_nav if @pagy.pages > 1 %></div></div>
