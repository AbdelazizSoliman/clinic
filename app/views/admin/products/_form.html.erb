<%= form_with model: [:admin, product], class:"grid gap-5 rounded-2xl bg-white p-6" do |f| %><% if product.errors.any? %><div class="rounded-xl bg-rose-50 p-4"><strong>راجع البيانات:</strong><ul><% product.errors.full_messages.each do |message| %><li><%= message %></li><% end %></ul></div><% end %><%= f.hidden_field :lock_version %><div class="grid gap-4 sm:grid-cols-2"><div><%= f.label :name,"اسم المنتج" %><%= f.text_field :name,required:true,class:"mt-1 w-full rounded-xl border p-3" %></div><div><%= f.label :slug,"الرابط المختصر — تغييره يكسر الروابط القديمة" %><%= f.text_field :slug,required:true,class:"mt-1 w-full rounded-xl border p-3",dir:"ltr" %></div><div><%= f.label :category_id,"التصنيف" %><%= f.collection_select :category_id,Category.active.order(:position,:name),:id,:name,{},class:"mt-1 w-full rounded-xl border p-3" %></div><div><%= f.label :brand_id,"العلامة" %><%= f.collection_select :brand_id,Brand.active.order(:name),:id,:name,{},class:"mt-1 w-full rounded-xl border p-3" %></div><div><%= f.label :sku,"SKU" %><%= f.text_field :sku,class:"mt-1 w-full rounded-xl border p-3",dir:"ltr" %></div><div><%= f.label :barcode,"الباركود" %><%= f.text_field :barcode,class:"mt-1 w-full rounded-xl border p-3",dir:"ltr" %></div><div><%= f.label :low_stock_threshold,"حد المخزون المنخفض" %><%= f.number_field :low_stock_threshold,min:0,class:"mt-1 w-full rounded-xl border p-3" %></div><div><%= f.label :maximum_order_quantity,"أقصى كمية للطلب" %><%= f.number_field :maximum_order_quantity,min:1,class:"mt-1 w-full rounded-xl border p-3" %></div></div><div><%= f.label :short_description,"وصف مختصر" %><%= f.text_area :short_description,class:"mt-1 w-full rounded-xl border p-3" %></div><div><%= f.label :description,"الوصف" %><%= f.text_area :description,rows:5,class:"mt-1 w-full rounded-xl border p-3" %></div><div class="flex flex-wrap gap-5"><%= f.label :requires_prescription do %><%= f.check_box :requires_prescription %> يتطلب روشتة<% end %><%= f.label :featured do %><%= f.check_box :featured %> مميز<% end %><%= f.label :active do %><%= f.check_box :active %> منشور ونشط<% end %><%= f.label :cold_chain_required do %><%= f.check_box :cold_chain_required %> سلسلة تبريد<% end %></div><%= f.submit "حفظ المنتج",class:"rounded-xl bg-pharmacy-700 px-5 py-3 font-bold text-white" %><% end %>
