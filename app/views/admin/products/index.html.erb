<% content_for :title, "إدارة المنتجات" %><div class="mx-auto max-w-7xl px-4 py-10"><div class="flex justify-between"><h1 class="text-3xl font-black">المنتجات</h1><%= link_to "منتج جديد", new_admin_product_path, class: "rounded-xl bg-pharmacy-700 px-5 py-3 font-bold text-white" %></div><%= form_with url: admin_products_path, method: :get, class: "mt-6 grid gap-3 rounded-2xl bg-white p-4 sm:grid-cols-3 lg:grid-cols-6" do |f| %><%= f.search_field :q, value: params[:q], placeholder: "الاسم أو SKU أو الباركود", class: "rounded-xl border p-2 lg:col-span-2" %><%= f.collection_select :category_id, Category.order(:name), :id, :name, {include_blank:"كل التصنيفات",selected:params[:category_id]}, class:"rounded-xl border p-2" %><%= f.collection_select :brand_id, Brand.order(:name), :id, :name, {include_blank:"كل العلامات",selected:params[:brand_id]}, class:"rounded-xl border p-2" %><%= f.select :active, [["كل الحالات",""],["نشط","true"],["غير نشط","false"]], {selected:params[:active]}, class:"rounded-xl border p-2" %><%= f.submit "تطبيق", class:"rounded-xl bg-slate-900 p-2 text-white" %><% end %><p class="mt-4"><%= @pagy.count %> منتج</p><div class="mt-4 overflow-x-auto rounded-2xl bg-white"><table class="w-full min-w-[900px] text-right text-sm"><thead class="bg-slate-50"><tr><th class="p-4">المنتج</th><th>التصنيف</th><th>السعر</th><th>فعلي</th><th>محجوز</th><th>متاح</th><th>الحالة</th></tr></thead><tbody><% @products.each do |product| %><tr class="border-t"><td class="p-4"><%= link_to product.name, admin_product_path(product), class:"font-black text-pharmacy-700" %><small class="block"><%= product.sku.presence || "بدون SKU" %></small></td><td><%= product.category.name %></td><td><%= product.price %> ج.م</td><td><%= product.stock_quantity %></td><td><%= product.active_reserved_quantity %></td><td><%= product.available_to_sell_quantity %></td><td><%= product.active? ? "نشط" : "متوقف" %><%= " · منخفض" if product.low_stock? %></td></tr><% end %></tbody></table></div></div>
