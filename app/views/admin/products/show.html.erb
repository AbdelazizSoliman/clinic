<div class="mx-auto max-w-6xl px-4 py-10"><div class="flex flex-wrap items-center justify-between gap-4"><div><h1 class="text-3xl font-black"><%= @product.name %></h1><p class="text-slate-500"><%= @product.sku %> · <%= @product.category.name %> · <%= @product.brand.name %></p></div><%= link_to "تعديل البيانات",edit_admin_product_path(@product),class:"rounded-xl border px-4 py-3 font-bold" %></div><div class="mt-6 grid gap-6 lg:grid-cols-3"><section class="rounded-2xl bg-white p-5"><h2 class="font-black">المخزون</h2><dl class="mt-4 space-y-2"><div class="flex justify-between"><dt>فعلي</dt><dd><%= @product.stock_quantity %></dd></div><div class="flex justify-between"><dt>محجوز</dt><dd><%= @product.active_reserved_quantity %></dd></div><div class="flex justify-between font-black"><dt>متاح للبيع</dt><dd><%= @product.available_to_sell_quantity %></dd></div></dl><%= form_with url:admin_inventory_adjustments_path,method: :post,class:"mt-5 grid gap-3" do %><%= hidden_field_tag :product_id,@product.id %><%= hidden_field_tag :lock_version,@product.lock_version %><%= select_tag :movement_type,options_for_select([["زيادة","manual_increase"],["نقص","manual_decrease"],["تالف","damaged"],["منتهي","expired"]]),class:"rounded-xl border p-2" %><%= number_field_tag :quantity,nil,min:1,required:true,class:"rounded-xl border p-2",placeholder:"الكمية" %><%= text_field_tag :reason,nil,required:true,class:"rounded-xl border p-2",placeholder:"السبب" %><%= submit_tag "تسجيل الحركة",class:"rounded-xl bg-slate-900 p-3 text-white" %><% end %></section><section class="rounded-2xl bg-white p-5"><h2 class="font-black">الأسعار</h2><%= form_with url:update_pricing_admin_product_path(@product),method: :patch,class:"mt-4 grid gap-3" do %><%= hidden_field_tag :lock_version,@product.lock_version %><%= number_field_tag :price,@product.price,min:0,step:"0.01",class:"rounded-xl border p-2",placeholder:"السعر" %><%= number_field_tag :compare_at_price,@product.compare_at_price,min:0,step:"0.01",class:"rounded-xl border p-2",placeholder:"السعر السابق" %><%= number_field_tag :cost_price,@product.cost_price,min:0,step:"0.01",class:"rounded-xl border p-2",placeholder:"سعر التكلفة — داخلي" %><%= text_field_tag :reason,nil,required:true,class:"rounded-xl border p-2",placeholder:"سبب التغيير" %><%= submit_tag "تحديث السعر",class:"rounded-xl bg-pharmacy-700 p-3 text-white" %><% end %></section><section class="rounded-2xl bg-white p-5"><h2 class="font-black">الصور</h2><div class="mt-3 grid grid-cols-3 gap-2"><% @product.images.each do |image| %><div><%= image_tag image.file,class:"aspect-square w-full rounded-lg object-cover",alt:image.alt_text %><%= button_to "رئيسية",set_primary_admin_product_image_path(@product,image),method: :patch,class:"text-xs" unless image.primary? %><%= button_to "حذف",admin_product_image_path(@product,image),method: :delete,class:"text-xs text-rose-700" %></div><% end %></div><%= form_with url:admin_product_images_path(@product),method: :post,multipart:true,class:"mt-4 grid gap-2" do %><%= file_field_tag :file,accept:"image/jpeg,image/png,image/webp",required:true %><%= text_field_tag :alt_text,nil,required:true,placeholder:"وصف الصورة",class:"rounded-xl border p-2" %><%= submit_tag "رفع صورة",class:"rounded-xl border p-2" %><% end %></section></div><section class="mt-6 rounded-2xl bg-white p-5"><h2 class="font-black">الحجوزات النشطة</h2><div class="mt-3 grid gap-2"><% @product.inventory_reservations.active.each do |reservation| %><p>الطلب <%= reservation.order.number %> · <%= reservation.quantity %> وحدة · <%= reservation.expires_at ? l(reservation.expires_at,format: :short) : "بلا انتهاء" %></p><% end %></div></section></div>
