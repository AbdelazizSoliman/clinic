<div class="mx-auto max-w-7xl px-4 py-10"><h1 class="text-3xl font-black">تاريخ الأسعار</h1><div class="mt-6 grid gap-3"><% @price_changes.each do |c| %><article class="grid gap-2 rounded-2xl bg-white p-5 sm:grid-cols-5"><strong><%= c.product.name %></strong><span><%= c.old_price_cents/100.0 %> ← <%= c.new_price_cents/100.0 %> ج.م</span><span><%= c.changed_by.full_name %></span><span><%= c.reason %></span><span><%= l(c.effective_at,format: :short) %></span></article><% end %></div></div>
