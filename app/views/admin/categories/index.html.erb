<div class="mx-auto max-w-5xl px-4 py-10"><div class="flex justify-between"><h1 class="text-3xl font-black">التصنيفات</h1><%= link_to "تصنيف جديد",new_admin_category_path,class:"rounded-xl bg-pharmacy-700 px-4 py-3 text-white" %></div><div class="mt-6 grid gap-3"><% @categories.each do |category| %><article class="flex justify-between rounded-2xl bg-white p-5"><div><strong><%= category.name %></strong><p class="text-sm text-slate-500"><%= category.products.count %> منتج · ترتيب <%= category.position %> · <%= category.active? ? "نشط" : "متوقف" %></p></div><div class="flex gap-3"><%= link_to "تعديل",edit_admin_category_path(category) %><%= button_to "إيقاف",deactivate_admin_category_path(category),method: :patch if category.active? %></div></article><% end %></div></div>
