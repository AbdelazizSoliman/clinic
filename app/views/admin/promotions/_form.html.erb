<%= form_with model: [:admin, promotion], class: "space-y-6" do |form| %><% if promotion.errors.any? %><div class="rounded-xl bg-rose-50 p-4" role="alert"><%= promotion.errors.full_messages.join("، ") %></div><% end %><%= form.hidden_field :lock_version %><div class="grid gap-4 sm:grid-cols-2"><% { name: "اسم العميل", internal_name: "الاسم الداخلي", discount_value: "قيمة الخصم", maximum_discount_cents: "الحد الأقصى بالقرش", minimum_subtotal_cents: "الحد الأدنى بالقرش", priority: "الأولوية", total_usage_limit: "حد الاستخدام الكلي", per_customer_usage_limit: "حد العميل" }.each do |field, label| %><div><%= form.label field, label, class: "mb-2 block font-bold" %><%= form.text_field field, class: "w-full rounded-xl border px-4 py-3" %></div><% end %><div><%= form.label :promotion_type, "نوع الحملة", class: "mb-2 block font-bold" %><%= form.select :promotion_type, Promotion::TYPES, {}, class: "w-full rounded-xl border px-4 py-3" %></div><div><%= form.label :discount_type, "نوع الخصم", class: "mb-2 block font-bold" %><%= form.select :discount_type, Promotion::DISCOUNT_TYPES, {}, class: "w-full rounded-xl border px-4 py-3" %></div><div><%= form.label :starts_at, "البداية", class: "mb-2 block font-bold" %><%= form.datetime_local_field :starts_at, class: "w-full rounded-xl border px-4 py-3" %></div><div><%= form.label :ends_at, "النهاية", class: "mb-2 block font-bold" %><%= form.datetime_local_field :ends_at, class: "w-full rounded-xl border px-4 py-3" %></div></div><div><%= form.label :description, "الوصف", class: "mb-2 block font-bold" %><%= form.text_area :description, rows: 3, class: "w-full rounded-xl border px-4 py-3" %></div><div class="grid gap-4 sm:grid-cols-2"><div><%= form.label :product_ids, "المنتجات المستهدفة", class: "mb-2 block font-bold" %><%= form.collection_select :product_ids, Product.active.order(:name), :id, :name, {}, multiple: true, class: "h-40 w-full rounded-xl border p-3" %></div><div><%= form.label :excluded_product_ids, "المنتجات المستبعدة", class: "mb-2 block font-bold" %><%= form.collection_select :excluded_product_ids, Product.active.order(:name), :id, :name, {}, multiple: true, class: "h-40 w-full rounded-xl border p-3" %></div><div><%= form.label :category_ids, "التصنيفات", class: "mb-2 block font-bold" %><%= form.collection_select :category_ids, Category.active.order(:name), :id, :name, {}, multiple: true, class: "h-32 w-full rounded-xl border p-3" %></div><div><%= form.label :brand_ids, "العلامات", class: "mb-2 block font-bold" %><%= form.collection_select :brand_ids, Brand.active.order(:name), :id, :name, {}, multiple: true, class: "h-32 w-full rounded-xl border p-3" %></div></div><div class="flex flex-wrap gap-5"><% { active: "نشطة", automatic: "تلقائية", stackable: "قابلة للجمع", first_order_only: "أول طلب", authenticated_only: "تتطلب الدخول", applies_to_prescription_products: "تشمل منتجات الروشتة" }.each do |field, label| %><label class="flex items-center gap-2"><%= form.check_box field %><%= label %></label><% end %></div><%= form.submit class: "rounded-xl bg-pharmacy-600 px-6 py-3 font-black text-white" %><% end %>
