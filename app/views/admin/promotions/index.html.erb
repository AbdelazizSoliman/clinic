<div class="mx-auto max-w-7xl px-4 py-10">
  <div class="flex items-center justify-between gap-4"><div><h1 class="text-3xl font-black">العروض والكوبونات</h1><p class="mt-2 text-slate-600">قواعد تجارية موثوقة تُعاد مراجعتها عند إنشاء الطلب.</p></div><%= link_to "حملة جديدة", new_admin_promotion_path, class: "rounded-xl bg-pharmacy-600 px-5 py-3 font-black text-white" %></div>
  <%= form_with url: admin_promotions_path, method: :get, class: "mt-6 flex flex-wrap gap-3" do |form| %><%= form.select :type, Promotion::TYPES, { include_blank: "كل الأنواع", selected: params[:type] }, class: "rounded-xl border px-4 py-3" %><%= form.select :sort, [["الأحدث", "newest"], ["الأولوية", "priority"], ["الاسم", "name"]], { selected: params[:sort] }, class: "rounded-xl border px-4 py-3" %><%= form.submit "تصفية", class: "rounded-xl bg-slate-900 px-5 font-bold text-white" %><% end %>
  <div class="mt-7 grid gap-4"><% @promotions.each do |promotion| %><article class="rounded-2xl bg-white p-5 shadow-sm sm:flex sm:items-center sm:justify-between"><div><%= link_to promotion.name, admin_promotion_path(promotion), class: "text-lg font-black text-pharmacy-800" %><p class="mt-1 text-sm text-slate-500"><%= promotion.promotion_type %> · <%= promotion.discount_type %> · أولوية <%= promotion.priority %></p></div><div class="mt-3 flex items-center gap-3 sm:mt-0"><span class="rounded-full bg-sky-100 px-3 py-1 text-sm font-bold"><%= promotion.lifecycle_status %></span><span class="text-sm"><%= promotion.redemptions.to_a.count(&:redeemed?) %> استخدام</span></div></article><% end %></div>
  <div class="mt-6"><%== @pagy.series_nav if @pagy.pages > 1 %></div>
</div>
