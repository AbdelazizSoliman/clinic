<div class="mx-auto max-w-6xl px-4 py-10"><div class="flex justify-between gap-4"><div><p class="text-sm text-slate-500"><%= @promotion.internal_name %></p><h1 class="text-3xl font-black"><%= @promotion.name %></h1><p class="mt-2"><%= @promotion.description %></p></div><div class="flex gap-2"><%= link_to "تعديل", edit_admin_promotion_path(@promotion), class: "rounded-xl border px-4 py-3 font-bold" %><% if @promotion.active? %><%= button_to "إيقاف", pause_admin_promotion_path(@promotion), method: :patch, class: "rounded-xl bg-amber-500 px-4 py-3 font-bold" %><% else %><%= button_to "تفعيل", activate_admin_promotion_path(@promotion), method: :patch, class: "rounded-xl bg-emerald-600 px-4 py-3 font-bold text-white" %><% end %></div></div><section class="mt-7 rounded-3xl bg-white p-6"><dl class="grid gap-4 sm:grid-cols-3"><div><dt class="text-slate-500">الحالة</dt><dd class="font-black"><%= @promotion.lifecycle_status %></dd></div><div><dt class="text-slate-500">نوع الخصم</dt><dd class="font-black"><%= @promotion.discount_type %> · <%= @promotion.discount_value %></dd></div><div><dt class="text-slate-500">الاستخدام</dt><dd class="font-black"><%= @promotion.redemptions.redeemed.count %></dd></div></dl></section><section class="mt-7 rounded-3xl bg-white p-6"><div class="flex justify-between"><h2 class="text-xl font-black">الكوبونات</h2><%= link_to "كوبون جديد", new_admin_promotion_coupon_path(@promotion), class: "font-black text-pharmacy-700" %></div><div class="mt-4 space-y-3"><% @promotion.coupons.each do |coupon| %><div class="flex justify-between rounded-xl border p-4"><span dir="ltr" class="font-black"><%= coupon.code %></span><span><%= coupon.active? ? "نشط" : "متوقف" %> · <%= coupon.redemptions.redeemed.count %> استخدام</span></div><% end %></div></section></div>
