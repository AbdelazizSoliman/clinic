<%= form_with model: [:admin, promotion, coupon], class: "space-y-4" do |form| %><% if coupon.errors.any? %><div role="alert" class="rounded-xl bg-rose-50 p-4"><%= coupon.errors.full_messages.join("، ") %></div><% end %><div><%= form.label :code, "الكود", class: "mb-2 block font-bold" %><%= form.text_field :code, dir: "ltr", class: "w-full rounded-xl border px-4 py-3" %></div><div class="grid gap-4 sm:grid-cols-2"><% %i[starts_at ends_at total_usage_limit per_customer_usage_limit minimum_subtotal_cents maximum_discount_cents].each do |field| %><div><%= form.label field, field.to_s.humanize, class: "mb-2 block font-bold" %><%= form.text_field field, class: "w-full rounded-xl border px-4 py-3" %></div><% end %></div><label class="flex gap-2"><%= form.check_box :active %> نشط</label><%= form.submit class: "rounded-xl bg-pharmacy-600 px-6 py-3 font-black text-white" %><% end %>
