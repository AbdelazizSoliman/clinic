<div class="mx-auto max-w-5xl px-4 py-10"><h1 class="text-3xl font-black">إعدادات الصيدلية والتطبيق</h1><p class="mt-2 text-slate-600">التغييرات تطبق على العمليات المستقبلية ولا تعيد كتابة الطلبات أو المنتجات السابقة.</p><% if @setting.errors.any? %><div class="mt-5 rounded-xl bg-red-50 p-4 text-red-800" role="alert"><%= @setting.errors.full_messages.join("، ") %></div><% end %><%= form_with model: @setting, url: admin_pharmacy_setting_path, method: :patch, class: "mt-7 space-y-6" do |form| %><%= form.hidden_field :lock_version %><section class="grid gap-4 rounded-2xl bg-white p-6 sm:grid-cols-2"><h2 class="text-xl font-black sm:col-span-2">ملف الصيدلية</h2><div><%= form.label :pharmacy_name, "اسم العرض", class: "block font-bold" %><%= form.text_field :pharmacy_name, required: true, class: "mt-1 w-full rounded-xl border p-3" %></div><div><%= form.label :legal_name, "الاسم القانوني", class: "block font-bold" %><%= form.text_field :legal_name, class: "mt-1 w-full rounded-xl border p-3" %></div><div><%= form.label :support_email, "بريد الدعم", class: "block font-bold" %><%= form.email_field :support_email, class: "mt-1 w-full rounded-xl border p-3" %></div><div><%= form.label :support_mobile, "هاتف الدعم", class: "block font-bold" %><%= form.telephone_field :support_mobile, class: "mt-1 w-full rounded-xl border p-3" %></div><div><%= form.label :support_hours, "ساعات الدعم", class: "block font-bold" %><%= form.text_field :support_hours, placeholder: "يوميًا 9 ص - 11 م", class: "mt-1 w-full rounded-xl border p-3" %></div><div><%= form.label :logo, "الشعار (PNG/JPEG/WebP حتى 2MB)", class: "block font-bold" %><%= form.file_field :logo, accept: "image/png,image/jpeg,image/webp", class: "mt-1 w-full rounded-xl border p-3" %></div><div class="sm:col-span-2"><%= form.label :footer_text, "نص التذييل", class: "block font-bold" %><%= form.text_area :footer_text, class: "mt-1 w-full rounded-xl border p-3" %></div></section><section class="grid gap-4 rounded-2xl bg-white p-6 sm:grid-cols-2"><h2 class="text-xl font-black sm:col-span-2">السياسات التشغيلية</h2><% [[:customer_registration_enabled,"السماح بتسجيل العملاء"],[:guest_cart_enabled,"السماح بسلة الضيف"],[:prescription_review_enabled,"تشغيل مراجعة الروشتات"],[:maintenance_mode,"وضع الصيانة"]].each do |field,label| %><label class="flex items-center gap-3 rounded-xl border p-4"><%= form.check_box field %><span><%= label %></span></label><% end %><div><%= form.label :default_low_stock_threshold, "حد المخزون المنخفض الافتراضي", class: "block font-bold" %><%= form.number_field :default_low_stock_threshold, min: 0, class: "mt-1 w-full rounded-xl border p-3" %></div><div><%= form.label :default_maximum_order_quantity, "أقصى كمية افتراضية", class: "block font-bold" %><%= form.number_field :default_maximum_order_quantity, min: 1, max: 100, class: "mt-1 w-full rounded-xl border p-3" %></div><div><%= form.label :default_reservation_minutes, "حجز الطلب العادي بالدقائق", class: "block font-bold" %><%= form.number_field :default_reservation_minutes, min: 5, max: 1440, class: "mt-1 w-full rounded-xl border p-3" %></div><div><%= form.label :pending_prescription_reservation_hours, "حجز طلب الروشتة بالساعات", class: "block font-bold" %><%= form.number_field :pending_prescription_reservation_hours, min: 1, max: 168, class: "mt-1 w-full rounded-xl border p-3" %></div><div class="sm:col-span-2"><%= form.label :maintenance_message, "رسالة الصيانة", class: "block font-bold" %><%= form.text_area :maintenance_message, class: "mt-1 w-full rounded-xl border p-3" %></div></section><div><%= label_tag :reason, "سبب التغيير", class: "block font-bold" %><%= text_field_tag :reason, nil, class: "mt-1 w-full rounded-xl border p-3" %></div><%= form.submit "حفظ الإعدادات", class: "rounded-xl bg-pharmacy-700 px-6 py-3 font-bold text-white" %><% end %></div>
