<div class="mx-auto max-w-7xl px-4 py-10"><h1 class="text-3xl font-black">سجل حركات المخزون</h1><div class="mt-6 overflow-x-auto rounded-2xl bg-white"><table class="w-full min-w-[800px] text-right"><thead><tr><th class="p-4">المنتج</th><th>النوع</th><th>قبل</th><th>التغير</th><th>بعد</th><th>السبب</th><th>المسؤول</th></tr></thead><tbody><% @movements.each do |m| %><tr class="border-t"><td class="p-4"><%= m.product.name %></td><td><%= m.movement_type %></td><td><%= m.quantity_before %></td><td dir="ltr"><%= m.quantity_delta %></td><td><%= m.quantity_after %></td><td><%= m.reason %></td><td><%= m.actor&.full_name || "النظام" %></td></tr><% end %></tbody></table></div></div>
