<div id="cart_drawer_content" class="flex min-h-0 flex-1 flex-col">
  <div class="flex-1 overflow-y-auto p-4"><% if cart&.requires_prescription? %><div class="mb-3 rounded-xl bg-amber-50 p-3 text-sm font-bold text-amber-900">⚕ تحتوي السلة على منتج يحتاج مراجعة روشتة قبل التأكيد.</div><% end %><% if cart&.items&.any? %><div class="space-y-3"><%= render partial: "carts/item", collection: cart.items.includes(product: :brand), as: :item %></div><% else %><div class="py-16 text-center"><div class="text-5xl">🛒</div><h3 class="mt-4 text-xl font-black">سلتك فارغة</h3><p class="mt-2 text-sm text-slate-500">أضف منتجاتك الصحية المفضلة وارجع هنا.</p><%= link_to "ابدأ التسوق", products_path, class: "mt-5 inline-block rounded-xl bg-pharmacy-600 px-5 py-3 font-black text-white" %></div><% end %></div>
  <% if cart&.items&.any? %><footer class="border-t bg-white p-5"><div class="flex justify-between text-lg font-black"><span>الإجمالي التقديري</span><span><%= number_to_currency(cart.subtotal_cents / 100.0, unit: "ج.م", format: "%n %u") %></span></div><p class="mt-2 text-xs text-slate-500">تُحدد رسوم التوصيل لاحقًا حسب العنوان.</p><%= link_to "متابعة إلى الدفع التجريبي", checkout_path, class: "mt-4 block rounded-xl bg-pharmacy-600 px-5 py-3 text-center font-black text-white" %><%= link_to "عرض السلة كاملة", cart_path, class: "mt-2 block text-center text-sm font-bold text-pharmacy-700" %><%= button_to "إفراغ السلة", clear_cart_path, method: :post, class: "mt-3 w-full text-center text-xs font-bold text-rose-600", form: { data: { turbo_confirm: "هل تريد إفراغ سلة التسوق بالكامل؟" } } %></footer><% end %>
</div>
