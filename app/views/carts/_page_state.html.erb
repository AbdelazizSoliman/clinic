<div id="cart_page_state">
  <% if cart&.items&.any? %>
    <% pricing = cart.promotion_calculation %>
    <div class="mt-8 grid gap-8 lg:grid-cols-[minmax(0,1fr)_23rem]">
      <section>
        <% if cart.items.any? { |item| !item.product.active? || !item.product.available? } %><div class="mb-4 rounded-xl bg-rose-50 p-4 text-sm font-bold text-rose-800">بعض المنتجات لم تعد متوفرة، لذلك استُبعدت من الإجمالي.</div><% end %>
        <% if cart.requires_prescription? %><div class="mb-4 rounded-xl bg-amber-50 p-4 leading-7 text-amber-900"><strong>مراجعة الروشتة:</strong> المنتجات التي تتطلب روشتة مستبعدة من الخصومات ما لم تسمح الحملة بذلك صراحة.</div><% end %>
        <div class="space-y-4"><%= render partial: "carts/item", collection: cart.items.includes(product: :brand), as: :item %></div>
      </section>
      <aside class="self-start rounded-3xl bg-white p-6 shadow-sm lg:sticky lg:top-44">
        <h2 class="text-xl font-black">ملخص الطلب</h2>
        <dl class="mt-5 space-y-4 text-sm">
          <div class="flex justify-between"><dt>الإجمالي الفرعي</dt><dd class="font-black"><%= number_to_currency(pricing.subtotal_cents / 100.0, unit: "ج.م", format: "%n %u") %></dd></div>
          <div class="flex justify-between text-emerald-700"><dt>الخصم</dt><dd><%= pricing.discount_cents.positive? ? "-#{number_to_currency(pricing.discount_cents / 100.0, unit: 'ج.م', format: '%n %u')}" : "—" %></dd></div>
          <div class="flex justify-between"><dt>رسوم التوصيل</dt><dd>تُحدد حسب العنوان</dd></div>
          <div class="flex justify-between border-t pt-4 text-lg font-black"><dt>الإجمالي قبل التوصيل</dt><dd><%= number_to_currency(pricing.total_cents / 100.0, unit: "ج.م", format: "%n %u") %></dd></div>
        </dl>
        <div class="mt-5 rounded-xl bg-slate-50 p-4">
          <% if cart.applied_coupon %>
            <div class="flex items-center justify-between"><span class="font-black" dir="ltr"><%= cart.applied_coupon.code %></span><%= button_to "إزالة", coupon_application_path, method: :delete, class: "text-sm font-bold text-rose-600" %></div>
          <% else %>
            <%= form_with url: coupon_application_path, class: "flex gap-2" do |form| %><%= label_tag :code, "كود الخصم", class: "sr-only" %><%= text_field_tag :code, nil, placeholder: "كود الخصم", autocomplete: "off", class: "min-w-0 flex-1 rounded-xl border px-3 py-2", dir: "ltr" %><%= form.submit "تطبيق", class: "rounded-xl bg-slate-900 px-4 font-bold text-white" %><% end %>
          <% end %>
        </div>
        <%= link_to "الانتقال إلى الدفع", checkout_path, class: "mt-6 block rounded-xl bg-pharmacy-600 px-5 py-4 text-center font-black text-white" %>
        <%= link_to "← متابعة التسوق", products_path, class: "mt-4 block text-center text-sm font-bold text-pharmacy-700" %>
      </aside>
    </div>
  <% else %>
    <div class="mt-10 rounded-3xl border border-dashed border-slate-300 bg-white p-12 text-center"><div class="text-6xl">🛒</div><h2 class="mt-4 text-2xl font-black">سلة التسوق فارغة</h2><p class="mt-2 text-slate-500">اكتشف احتياجاتك اليومية وأضفها بسهولة.</p><%= link_to "متابعة التسوق", products_path, class: "mt-6 inline-block rounded-xl bg-pharmacy-600 px-6 py-3 font-black text-white" %></div>
  <% end %>
</div>
