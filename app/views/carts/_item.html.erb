<article class="rounded-2xl border border-slate-200 bg-white p-4" id="cart_item_<%= item.id %>">
  <div class="flex gap-3"><%= link_to product_path(item.product), class: "grid size-20 shrink-0 place-items-center rounded-xl bg-pharmacy-50 text-3xl", aria: { label: "عرض #{item.product.name}" } do %>💊<% end %><div class="min-w-0 flex-1"><p class="text-xs font-bold text-pharmacy-600"><%= item.product.brand.name %></p><%= link_to item.product.name, product_path(item.product), class: "mt-1 block font-black leading-6" %><p class="mt-1 text-sm font-black text-pharmacy-700"><%= number_to_currency(item.product.price, unit: "ج.م", format: "%n %u") %></p><% unless item.product.active? && item.product.available? %><p class="mt-1 text-xs font-bold text-rose-600">غير متوفر — مستبعد من الإجمالي</p><% end %></div><%= button_to "حذف", cart_item_path(item), method: :delete, class: "self-start text-sm font-bold text-rose-600", form: { data: { turbo_stream: true } }, aria: { label: "إزالة #{item.product.name}" } %></div>
  <div class="mt-3 flex items-center justify-between gap-3"><div class="inline-flex items-center rounded-xl border border-slate-300" aria-label="كمية <%= item.product.name %>"><%= button_to "+", cart_item_path(item), method: :patch, params: { cart_item: { quantity: [item.quantity + 1, 10].min } }, class: "grid size-10 place-items-center font-black", form: { data: { turbo_stream: true } }, aria: { label: "زيادة الكمية" } %><%= form_with model: item, url: cart_item_path(item), method: :patch, data: { controller: "autosubmit", action: "change->autosubmit#submit" } do |form| %><%= form.number_field :quantity, min: 1, max: [10, item.product.stock_quantity].min, class: "w-14 border-x border-slate-200 py-2 text-center text-sm font-black", aria: { label: "الكمية" } %><% end %><%= button_to "−", cart_item_path(item), method: :patch, params: { cart_item: { quantity: [item.quantity - 1, 1].max } }, class: "grid size-10 place-items-center font-black", form: { data: { turbo_stream: true } }, aria: { label: "تقليل الكمية" } %></div><p class="font-black"><%= item.product.active? && item.product.available? ? number_to_currency(item.subtotal_cents / 100.0, unit: "ج.م", format: "%n %u") : "—" %></p></div>
</article>
