<% content_for :title, "صيدليتي | رعاية صحية تصل إلى بابك" %>
<section class="overflow-hidden bg-gradient-to-l from-pharmacy-900 via-pharmacy-700 to-pharmacy-600 text-white">
  <div class="mx-auto grid max-w-7xl items-center gap-10 px-4 py-14 sm:px-6 lg:grid-cols-2 lg:px-8 lg:py-24">
    <div><span class="rounded-full bg-white/15 px-4 py-2 text-sm font-bold">صحتك أولويتنا كل يوم</span><h1 class="mt-6 text-4xl font-black leading-tight sm:text-5xl">كل ما تحتاجه لصحتك<br><span class="text-emerald-200">يصلك بأمان وسرعة</span></h1><p class="mt-5 max-w-xl text-lg leading-8 text-emerald-50">تسوق منتجات العناية والأدوية والفيتامينات من علامات موثوقة، مع دعم صيدلي متخصص.</p><div class="mt-8 flex flex-wrap gap-3"><%= link_to "تسوق الآن", products_path, class: "rounded-xl bg-white px-7 py-3.5 font-black text-pharmacy-700 hover:bg-emerald-50" %><%= link_to "اكتشف العروض", root_path(anchor: "offers"), class: "rounded-xl border border-white/40 px-7 py-3.5 font-bold hover:bg-white/10" %></div></div>
    <div class="relative mx-auto grid aspect-square w-full max-w-md place-items-center rounded-[3rem] bg-white/10 shadow-2xl" aria-hidden="true"><div class="grid size-64 place-items-center rounded-full bg-white/95 text-9xl shadow-xl">⚕️</div><span class="absolute left-4 top-12 rounded-2xl bg-white px-4 py-3 text-sm font-bold text-pharmacy-700 shadow-lg">✓ منتجات أصلية</span><span class="absolute bottom-10 right-0 rounded-2xl bg-white px-4 py-3 text-sm font-bold text-pharmacy-700 shadow-lg">🚚 توصيل سريع</span></div>
  </div>
</section>

<section id="categories" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
  <div class="mb-8 flex items-end justify-between"><div><p class="font-bold text-pharmacy-600">تسوق حسب احتياجك</p><h2 class="mt-1 text-3xl font-black">الأقسام الرئيسية</h2></div><%= link_to "عرض المنتجات ←", products_path, class: "hidden font-bold text-pharmacy-700 sm:block" %></div>
  <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6"><% @categories.each do |category| %><%= link_to category_path(category), class: "group rounded-2xl border border-slate-200 bg-white p-5 text-center shadow-sm hover:border-pharmacy-500 hover:shadow-md" do %><span class="mx-auto grid size-16 place-items-center rounded-2xl bg-pharmacy-50 text-3xl transition group-hover:scale-110" aria-hidden="true"><%= category.icon %></span><h3 class="mt-4 font-black"><%= category.name %></h3><p class="mt-1 text-xs text-slate-500"><%= category.products.active.count %> منتج</p><% end %><% end %></div>
</section>

<section class="bg-white py-16"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div class="mb-8"><p class="font-bold text-pharmacy-600">مختارة بعناية</p><h2 class="mt-1 text-3xl font-black">منتجات مميزة</h2></div><div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4"><%= render partial: "products/product_card", collection: @featured_products, as: :product %></div></div></section>

<section id="offers" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8"><div class="mb-8 rounded-3xl bg-rose-50 px-6 py-7 sm:flex sm:items-center sm:justify-between"><div><p class="font-bold text-rose-600">لفترة محدودة</p><h2 class="mt-1 text-3xl font-black">العروض الحالية</h2></div><span class="mt-3 inline-block rounded-full bg-rose-500 px-4 py-2 text-sm font-black text-white sm:mt-0">وفّر على احتياجاتك اليومية</span></div><div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4"><%= render partial: "products/product_card", collection: @offer_products, as: :product %></div></section>

<section class="bg-pharmacy-50 py-16"><div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"><div class="text-center"><p class="font-bold text-pharmacy-600">لماذا صيدليتي؟</p><h2 class="mt-1 text-3xl font-black">رعاية تستحق ثقتك</h2></div><div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4"><% [["🛡️", "منتجات أصلية", "مصادر معتمدة وعلامات تجارية موثوقة"], ["🚚", "توصيل سريع", "توصيل آمن يحافظ على جودة منتجاتك"], ["💬", "دعم صيدلي", "إرشاد متخصص للإجابة عن استفساراتك"], ["🔒", "تسوق آمن", "خصوصيتك وبياناتك في أمان دائمًا"]].each do |icon, title, text| %><article class="rounded-2xl bg-white p-6 text-center shadow-sm"><span class="mx-auto grid size-14 place-items-center rounded-full bg-pharmacy-100 text-2xl" aria-hidden="true"><%= icon %></span><h3 class="mt-4 text-lg font-black"><%= title %></h3><p class="mt-2 text-sm leading-6 text-slate-600"><%= text %></p></article><% end %></div></div></section>
