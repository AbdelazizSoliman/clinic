<% content_for :title, "طلباتي | صيدليتي" %><div class="mx-auto max-w-6xl px-4 py-12 sm:px-6"><nav aria-label="مسار التنقل" class="text-sm text-slate-500"><%= link_to "الرئيسية", root_path %> / <%= link_to "حسابي", account_path %> / <span>طلباتي</span></nav><header class="mt-6"><h1 class="text-3xl font-black">طلباتي</h1><p class="mt-2 text-slate-600">تابع الطلبات المحفوظة وحالة مراجعة الروشتة.</p></header><% if @orders.empty? %><section class="mt-10 rounded-3xl border border-dashed bg-white p-12 text-center"><div class="text-6xl">📦</div><h2 class="mt-4 text-2xl font-black">لا توجد طلبات بعد</h2><%= link_to "ابدأ التسوق", products_path, class: "mt-6 inline-block rounded-xl bg-pharmacy-600 px-6 py-3 font-black text-white" %></section><% else %><div class="mt-8 space-y-4"><% @orders.each do |order| %><article class="grid gap-4 rounded-2xl border bg-white p-5 shadow-sm sm:grid-cols-[1fr_auto_auto] sm:items-center"><div><%= link_to order.number, order_path(order), class: "text-lg font-black text-pharmacy-800" %><p class="mt-1 text-sm text-slate-500"><%= l(order.submitted_at, format: :short) %> · <%= order.items.sum(&:quantity) %> قطعة</p></div><div><span class="rounded-full bg-pharmacy-100 px-3 py-1 text-xs font-black"><%= order_status_label(order) %></span><% if order.prescription_required? %><span class="mr-2 text-xs font-bold text-amber-700">يتطلب روشتة</span><% end %><p class="mt-2 text-xs text-slate-500"><%= payment_status_label(order) %></p></div><strong><%= number_to_currency(order.total_cents / 100.0, unit: "ج.م", format: "%n %u") %></strong></article><% end %></div><% end %></div>
