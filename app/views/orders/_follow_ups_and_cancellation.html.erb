<section class="mx-auto mt-8 max-w-6xl rounded-2xl bg-white p-5"><h2 class="text-xl font-black">متابعات الطلب</h2><div class="mt-4 grid gap-4"><% order.follow_ups.each do |follow_up| %><article class="rounded-xl border p-4"><div class="flex flex-wrap justify-between gap-2"><strong><%= follow_up.subject %></strong><span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-bold"><%= follow_up.status %></span></div><p class="mt-2"><%= follow_up.customer_message %></p><small class="text-slate-500"><%= l(follow_up.created_at, format: :short) %><%= " · الرد مطلوب قبل #{l(follow_up.due_at, format: :short)}" if follow_up.due_at %></small><div class="mt-3 space-y-2"><% follow_up.customer_messages.each do |message| %><p class="rounded-lg bg-slate-50 p-3"><strong><%= message.author.customer? ? "ردك" : "فريق الصيدلية" %>:</strong> <%= message.body %></p><% end %></div><% if follow_up.awaiting_customer? %><%= form_with url: respond_order_follow_up_path(order, follow_up), method: :post, class: "mt-4 grid gap-2" do %><%= hidden_field_tag :lock_version, follow_up.lock_version %><%= label_tag :body, "ردك على المتابعة" %><%= text_area_tag :body, nil, required: true, class: "rounded-xl border p-3" %><%= submit_tag "إرسال الرد", class: "rounded-xl bg-pharmacy-700 px-4 py-3 font-bold text-white" %><% end %><% end %></article><% end %></div><% if order.follow_ups.empty? %><p class="mt-3 text-slate-500">لا توجد متابعة مطلوبة حاليًا.</p><% end %></section>
<% if order.customer_cancellable? %><section class="mx-auto mt-8 max-w-6xl rounded-2xl border border-rose-200 bg-white p-5"><h2 class="font-black">إلغاء الطلب</h2><p class="mt-2 text-sm text-slate-600">سيتم تحرير المخزون المحجوز ولن تُستعاد المنتجات إلى السلة تلقائيًا.</p><%= form_with url: cancel_order_path(order), method: :patch, class: "mt-4 flex flex-col gap-3 sm:flex-row", data: { turbo_confirm: "هل تريد إلغاء الطلب؟" } do %><%= hidden_field_tag :lock_version, order.lock_version %><%= text_field_tag :reason, nil, required: true, placeholder: "سبب الإلغاء", class: "flex-1 rounded-xl border p-3" %><%= submit_tag "إلغاء الطلب", class: "rounded-xl bg-rose-700 px-5 py-3 font-bold text-white" %><% end %></section><% end %>
