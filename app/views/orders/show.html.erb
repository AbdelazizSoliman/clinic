<% content_for :title, "الطلب #{@order.number} | صيدليتي" %><div class="mx-auto max-w-6xl px-4 py-12 sm:px-6"><nav aria-label="مسار التنقل" class="text-sm text-slate-500"><%= link_to "حسابي", account_path %> / <%= link_to "طلباتي", orders_path %> / <span><%= @order.number %></span></nav><header class="mt-6 rounded-3xl bg-pharmacy-900 p-7 text-white"><p class="text-sm text-emerald-200">تم استلام الطلب — لا يعني ذلك تأكيده أو دفعه</p><h1 class="mt-2 text-3xl font-black"><%= @order.number %></h1><div class="mt-4 flex flex-wrap gap-3"><span class="rounded-full bg-white/15 px-3 py-1 text-sm font-bold"><%= order_status_label(@order) %></span><span class="rounded-full bg-white/15 px-3 py-1 text-sm font-bold"><%= payment_status_label(@order) %></span></div></header><div class="mt-8 grid gap-7 lg:grid-cols-[minmax(0,1fr)_22rem]"><div class="space-y-6"><section class="rounded-3xl bg-white p-6 shadow-sm"><h2 class="text-xl font-black">المنتجات المحفوظة وقت الطلب</h2><div class="mt-5 divide-y"><% @order.items.each do |item| %><article class="flex gap-4 py-4"><span class="grid size-16 place-items-center rounded-xl bg-pharmacy-50 text-3xl">💊</span><div class="min-w-0 flex-1"><h3 class="font-black"><%= item.product_name %></h3><p class="mt-1 text-sm text-slate-500"><%= item.brand_name %> · <%= item.category_name %></p><p class="mt-1 text-sm"><%= item.quantity %> × <%= number_to_currency(item.unit_price_cents / 100.0, unit: "ج.م", format: "%n %u") %></p><% if item.requires_prescription? %><span class="mt-2 inline-block text-xs font-bold text-amber-700">يتطلب روشتة</span><% end %></div><strong><%= number_to_currency(item.line_total_cents / 100.0, unit: "ج.م", format: "%n %u") %></strong></article><% end %></div></section><section class="rounded-3xl bg-white p-6 shadow-sm"><h2 class="text-xl font-black">عنوان التوصيل المحفوظ</h2><p class="mt-4 font-black"><%= @order.order_address.recipient_name %> · <span dir="ltr"><%= @order.order_address.mobile_number %></span></p><address class="mt-2 not-italic leading-7 text-slate-600"><%= @order.order_address.summary %></address><% if @order.order_address.delivery_notes.present? %><p class="mt-2 text-sm text-slate-500"><%= @order.order_address.delivery_notes %></p><% end %></section><% if @order.prescription %><section class="rounded-3xl border border-amber-200 bg-amber-50 p-6"><h2 class="text-xl font-black text-amber-950">الروشتة قيد المراجعة</h2><p class="mt-2 text-sm text-amber-900">لن يتم تأكيد المنتجات الطبية قبل مراجعة الصيدلي.</p><ul class="mt-4 space-y-2"><% @order.prescription.images.each do |image| %><li><%= link_to "تنزيل #{image.filename}", order_prescription_file_path(@order, image.id), class: "font-bold text-amber-950 underline" %></li><% end %></ul></section><% end %></div><aside class="self-start rounded-3xl bg-white p-6 shadow-sm lg:sticky lg:top-40"><h2 class="text-xl font-black">ملخص الطلب</h2><dl class="mt-5 space-y-3 text-sm"><div class="flex justify-between"><dt>المجموع الفرعي</dt><dd><%= number_to_currency(@order.subtotal_cents / 100.0, unit: "ج.م", format: "%n %u") %></dd></div><div class="flex justify-between"><dt>التوصيل</dt><dd><%= @order.delivery_fee_cents.zero? ? "مجاني" : number_to_currency(@order.delivery_fee_cents / 100.0, unit: "ج.م", format: "%n %u") %></dd></div><div class="flex justify-between border-t pt-4 text-lg font-black"><dt>الإجمالي</dt><dd><%= number_to_currency(@order.total_cents / 100.0, unit: "ج.م", format: "%n %u") %></dd></div></dl><p class="mt-5 text-sm"><strong>الدفع:</strong> <%= payment_method_label(@order) %> — <%= payment_status_label(@order) %></p><p class="mt-3 text-xs leading-6 text-slate-500">موعد التوصيل تقديري وغير ملزم حتى تأكيد الطلب.</p><div class="mt-6 grid gap-3"><%= link_to "كل الطلبات", orders_path, class: "rounded-xl border px-4 py-3 text-center font-bold" %><%= link_to "متابعة التسوق", products_path, class: "rounded-xl bg-pharmacy-600 px-4 py-3 text-center font-black text-white" %></div></aside></div></div>
