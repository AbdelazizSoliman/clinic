<%= form_with url: @browsing_path, method: :get, id: "#{form_id}-filters", class: "space-y-6", data: { turbo_frame: "products_browser", turbo_action: "advance", action: ("submit->mobile-filters#close" if form_id == "mobile") } do |form| %>
  <div>
    <%= form.label :q, "ابحث في المنتجات", class: "mb-2 block text-sm font-black text-slate-800" %>
    <%= form.search_field :q, value: @active_browsing_params["q"], placeholder: "اسم، علامة أو قسم", class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2.5 text-sm focus:border-pharmacy-500" %>
  </div>

  <% unless @locked_category %>
    <div>
      <%= form.label :category, "القسم", class: "mb-2 block text-sm font-black text-slate-800" %>
      <%= form.select :category, options_from_collection_for_select(@categories, :slug, :name, @active_browsing_params["category"]), { include_blank: "كل الأقسام" }, class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2.5 text-sm" %>
    </div>
  <% end %>

  <div>
    <%= form.label :brand, "العلامة التجارية", class: "mb-2 block text-sm font-black text-slate-800" %>
    <%= form.select :brand, options_from_collection_for_select(@brands, :slug, :name, @active_browsing_params["brand"]), { include_blank: "كل العلامات" }, class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2.5 text-sm" %>
  </div>

  <fieldset>
    <legend class="mb-2 text-sm font-black text-slate-800">نطاق السعر</legend>
    <div class="grid grid-cols-2 gap-2">
      <div><%= form.label :min_price, "أقل سعر", class: "sr-only" %><%= form.number_field :min_price, value: @active_browsing_params["min_price"], min: 0, step: 1, placeholder: "من", class: "w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm" %></div>
      <div><%= form.label :max_price, "أعلى سعر", class: "sr-only" %><%= form.number_field :max_price, value: @active_browsing_params["max_price"], min: 0, step: 1, placeholder: "إلى", class: "w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm" %></div>
    </div>
    <% if @products_query.invalid_price_range? %><p class="mt-2 text-xs font-bold text-rose-600" role="alert">أقل سعر يجب ألا يتجاوز أعلى سعر.</p><% end %>
  </fieldset>

  <fieldset class="space-y-3">
    <legend class="mb-3 text-sm font-black text-slate-800">خيارات إضافية</legend>
    <% [["discounted", "العروض والخصومات"], ["available", "المتوفر حاليًا"], ["prescription", "يتطلب روشتة"], ["featured", "المنتجات المميزة"]].each do |key, label| %>
      <label class="flex cursor-pointer items-center gap-3 text-sm text-slate-700"><%= hidden_field_tag key, "false", id: nil %><%= check_box_tag key, "true", @active_browsing_params[key] == "true", id: "#{form_id}-#{key}", class: "size-4 rounded border-slate-300 text-pharmacy-600 focus:ring-pharmacy-500" %><span><%= label %></span></label>
    <% end %>
  </fieldset>

  <%= hidden_field_tag :sort, @active_browsing_params["sort"] if @active_browsing_params["sort"].present? %>
  <div class="flex gap-2"><%= form.submit "عرض النتائج", class: "flex-1 cursor-pointer rounded-xl bg-pharmacy-600 px-4 py-3 text-sm font-black text-white hover:bg-pharmacy-700" %><%= link_to "مسح", @browsing_path, data: { turbo_frame: "products_browser", turbo_action: "advance" }, class: "rounded-xl border border-slate-300 px-4 py-3 text-sm font-bold text-slate-600 hover:bg-slate-50" %></div>
<% end %>
