<div data-wishlist-control-product-id="<%= product.id %>" class="<%= local_assigns[:detail] ? "" : "absolute left-3 top-3 z-10" %>">
  <% if user_signed_in? %><% item = wishlist_item_for(product) %><% if item %><%= button_to "♥", wishlist_item_path(item), method: :delete, aria: { label: "إزالة #{product.name} من المفضلة", pressed: true }, class: "grid size-10 place-items-center rounded-full bg-white text-xl text-rose-500 shadow-sm" %><% else %><%= button_to "♡", wishlist_items_path, params: { wishlist_item: { product_id: product.id } }, aria: { label: "إضافة #{product.name} إلى المفضلة", pressed: false }, class: "grid size-10 place-items-center rounded-full bg-white text-xl text-slate-500 shadow-sm" %><% end %>
  <% else %><div data-controller="wishlist" data-wishlist-product-id-value="<%= product.id %>"><button type="button" data-wishlist-target="button" data-action="wishlist#toggle" aria-pressed="false" class="grid size-10 place-items-center rounded-full bg-white text-xl text-slate-500 shadow-sm"><span data-wishlist-target="icon">♡</span></button></div><% end %>
</div>
