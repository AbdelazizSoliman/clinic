<%= link_to product_path(product), data: { recently_viewed_target: "item", product_id: product.id }, class: "hidden min-w-44 rounded-2xl border border-slate-200 bg-white p-3 hover:border-pharmacy-500" do %>
  <span class="grid aspect-square place-items-center rounded-xl bg-pharmacy-50 text-4xl" aria-hidden="true">💊</span><span class="mt-3 block truncate text-xs font-bold text-pharmacy-600"><%= product.brand.name %></span><span class="mt-1 block line-clamp-2 text-sm font-black"><%= product.name %></span><span class="mt-2 block font-black text-pharmacy-700"><%= number_to_currency(product.price, unit: "ج.م", format: "%n %u") %></span>
<% end %>
