<article class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
  <%= link_to product_path(product), class: "relative block bg-gradient-to-br from-slate-50 to-pharmacy-50 p-4", aria: { label: "عرض تفاصيل #{product.name}" } do %>
    <% if product.primary_image&.file&.attached? %><%= image_tag product.primary_image.file, alt: product.primary_image.alt_text, class: "aspect-square w-full rounded-xl bg-white object-contain shadow-inner" %><% else %><div class="grid aspect-square place-items-center rounded-xl bg-white text-6xl shadow-inner" aria-hidden="true">💊</div><% end %>
    <% if product.discounted? %><span class="absolute right-3 top-3 rounded-full bg-rose-500 px-2.5 py-1 text-xs font-black text-white">سعر عرض مرجعي <%= product.discount_percentage %>٪</span><% end %>
    <% if product.requires_prescription? %><span class="absolute bottom-3 right-3 rounded-lg bg-amber-100 px-2 py-1 text-xs font-bold text-amber-800">يتطلب روشتة</span><% end %>
  <% end %>
  <%= render "products/wishlist_control", product: %>
  <div class="flex flex-1 flex-col p-4">
    <p class="mb-1 text-xs font-bold text-pharmacy-600"><%= product.brand.name %></p>
    <h3 class="line-clamp-2 min-h-12 font-bold leading-6" title="<%= product.name %>"><%= link_to product.name, product_path(product), class: "hover:text-pharmacy-600" %></h3>
    <div class="mt-3 flex min-h-12 flex-wrap items-baseline gap-x-2"><span class="text-lg font-black text-pharmacy-700"><%= number_to_currency(product.price, unit: "ج.م", format: "%n %u") %></span><% if product.discounted? %><del class="text-sm text-slate-400"><%= number_to_currency(product.compare_at_price, unit: "ج.م", format: "%n %u") %></del><% end %></div>
    <p class="mt-2 text-xs font-bold <%= product.available? ? "text-pharmacy-600" : "text-rose-600" %>"><%= product.available? ? "متوفر" : "غير متوفر حاليًا" %></p>
    <%= render "products/cart_control", product:, quantity: cart_quantity_for(product) %>
    <span id="product-stock-<%= product.id %>" class="sr-only"><%= product.available? ? "متاح بحد أقصى #{[product.available_to_sell_quantity, 10].min}" : "غير متوفر ولا يمكن إضافته" %></span>
  </div>
</article>
