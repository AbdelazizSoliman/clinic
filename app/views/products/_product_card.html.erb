<article class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg" data-controller="product-purchase wishlist" data-product-purchase-product-id-value="<%= product.id %>" data-product-purchase-available-value="<%= product.available? %>" data-product-purchase-max-value="<%= [product.stock_quantity, 10].min %>" data-wishlist-product-id-value="<%= product.id %>">
  <%= link_to product_path(product), class: "relative block bg-gradient-to-br from-slate-50 to-pharmacy-50 p-4", aria: { label: "عرض تفاصيل #{product.name}" } do %>
    <div class="grid aspect-square place-items-center rounded-xl bg-white text-6xl shadow-inner" aria-hidden="true">💊</div>
    <% if product.discounted? %><span class="absolute right-3 top-3 rounded-full bg-rose-500 px-2.5 py-1 text-xs font-black text-white">خصم <%= product.discount_percentage %>٪</span><% end %>
    <% if product.requires_prescription? %><span class="absolute bottom-3 right-3 rounded-lg bg-amber-100 px-2 py-1 text-xs font-bold text-amber-800">يتطلب روشتة</span><% end %>
  <% end %>
  <button type="button" data-wishlist-target="button" data-action="wishlist#toggle" aria-pressed="false" class="absolute left-3 top-3 z-10 grid size-10 place-items-center rounded-full bg-white text-xl text-slate-500 shadow-sm hover:text-rose-500"><span data-wishlist-target="icon">♡</span></button>
  <div class="flex flex-1 flex-col p-4">
    <p class="mb-1 text-xs font-bold text-pharmacy-600"><%= product.brand.name %></p>
    <h3 class="line-clamp-2 min-h-12 font-bold leading-6" title="<%= product.name %>"><%= link_to product.name, product_path(product), class: "hover:text-pharmacy-600" %></h3>
    <div class="mt-3 flex min-h-12 flex-wrap items-baseline gap-x-2"><span class="text-lg font-black text-pharmacy-700"><%= number_to_currency(product.price, unit: "ج.م", format: "%n %u") %></span><% if product.discounted? %><del class="text-sm text-slate-400"><%= number_to_currency(product.compare_at_price, unit: "ج.م", format: "%n %u") %></del><% end %></div>
    <p class="mt-2 text-xs font-bold <%= product.available? ? "text-pharmacy-600" : "text-rose-600" %>"><%= product.available? ? "متوفر" : "غير متوفر حاليًا" %></p>
    <button type="button" data-product-purchase-target="add" data-action="product-purchase#add" <%= "disabled" unless product.available? %> aria-describedby="product-stock-<%= product.id %>" class="mt-auto w-full rounded-xl px-4 py-3 text-sm font-bold <%= product.available? ? "bg-pharmacy-600 text-white hover:bg-pharmacy-700" : "cursor-not-allowed bg-slate-100 text-slate-400" %>"><%= product.available? ? "أضف إلى السلة" : "غير متوفر" %></button>
    <div data-product-purchase-target="controls" class="mt-auto hidden flex items-center justify-between rounded-xl border border-pharmacy-200 bg-pharmacy-50 p-1"><button type="button" data-action="product-purchase#increase" class="grid size-10 place-items-center font-black" aria-label="زيادة كمية <%= product.name %>">+</button><span data-product-purchase-target="quantity" class="font-black" aria-live="polite">1</span><button type="button" data-action="product-purchase#decrease" class="grid size-10 place-items-center font-black" aria-label="تقليل كمية <%= product.name %>">−</button></div>
    <span id="product-stock-<%= product.id %>" class="sr-only"><%= product.available? ? "متاح بحد أقصى #{[product.stock_quantity, 10].min}" : "غير متوفر ولا يمكن إضافته" %></span>
  </div>
</article>
