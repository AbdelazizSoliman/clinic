<% content_for :title, "#{@product.name} | صيدليتي" %>
<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8" data-controller="recently-viewed" data-recently-viewed-current-id-value="<%= @product.id %>">
  <nav aria-label="مسار التنقل" class="text-sm text-slate-500"><%= link_to "الرئيسية", root_path %> / <%= link_to @product.category.name, category_path(@product.category) %> / <span><%= @product.name %></span></nav>
  <article class="mt-7 grid gap-10 rounded-3xl bg-white p-5 shadow-sm sm:p-8 lg:grid-cols-2">
    <% if @product.primary_image&.file&.attached? %><%= image_tag @product.primary_image.file, alt: @product.primary_image.alt_text, class: "aspect-square w-full rounded-3xl bg-white object-contain" %><% else %><div class="grid aspect-square place-items-center rounded-3xl bg-gradient-to-br from-slate-50 to-pharmacy-50 text-9xl" aria-label="صورة توضيحية للمنتج">💊</div><% end %>
    <div class="flex flex-col justify-center"><div class="flex items-start justify-between gap-3"><div><p class="font-bold text-pharmacy-600"><%= @product.brand.name %></p><h1 class="mt-2 text-3xl font-black leading-tight sm:text-4xl"><%= @product.name %></h1></div><%= render "products/wishlist_control", product: @product, detail: true %></div><p class="mt-4 leading-8 text-slate-600"><%= @product.short_description %></p>
      <div class="mt-6 flex items-end gap-3"><span class="text-3xl font-black text-pharmacy-700"><%= number_to_currency(@product.price, unit: "ج.م", format: "%n %u") %></span><% if @product.discounted? %><del class="text-lg text-slate-400"><%= number_to_currency(@product.compare_at_price, unit: "ج.م", format: "%n %u") %></del><span class="rounded-full bg-rose-100 px-3 py-1 text-sm font-black text-rose-600">وفّر <%= @product.discount_percentage %>٪</span><% end %></div>
      <div class="mt-6 flex flex-wrap gap-3"><span class="rounded-lg px-3 py-2 text-sm font-bold <%= @product.available? ? "bg-pharmacy-50 text-pharmacy-700" : "bg-rose-50 text-rose-700" %>"><%= @product.available? ? "✓ متوفر في المخزون" : "غير متوفر حاليًا" %></span><% if @product.requires_prescription? %><span class="rounded-lg bg-amber-100 px-3 py-2 text-sm font-bold text-amber-800">⚕ يتطلب روشتة طبية</span><% end %></div>
      <% if @product.available? %><%= form_with url: cart_items_path, scope: :cart_item, class: "mt-7 flex gap-3" do |form| %><%= form.hidden_field :product_id, value: @product.id %><%= form.label :quantity, "الكمية", class: "sr-only" %><%= form.number_field :quantity, min: 1, max: [@product.available_to_sell_quantity, 10].min, value: 1, class: "w-24 rounded-xl border border-slate-300 px-3 text-center font-black" %><%= form.submit "أضف إلى السلة", class: "flex-1 cursor-pointer rounded-xl bg-pharmacy-600 px-6 py-4 text-lg font-black text-white hover:bg-pharmacy-700" %><% end %><p class="mt-2 text-xs text-slate-500">في سلتك حاليًا: <%= cart_quantity_for(@product) %>. الحد الأقصى المتاح: <%= [@product.available_to_sell_quantity, 10].min %>.</p><% else %><button type="button" disabled class="mt-7 w-full cursor-not-allowed rounded-xl bg-slate-300 px-6 py-4 text-lg font-black text-white">غير متوفر حاليًا</button><% end %>
      <% if @product.requires_prescription? %><div class="mt-4 rounded-xl bg-amber-50 p-4 text-sm leading-6 text-amber-900"><strong>مراجعة صيدلي مطلوبة:</strong> يمكنك إضافة المنتج الآن، وسنطلب الروشتة في خطوة الدفع التجريبية قبل التأكيد.</div><% end %>
    </div>
  </article>
  <section class="mt-8 rounded-3xl bg-white p-7 shadow-sm"><h2 class="text-2xl font-black">تفاصيل المنتج</h2><p class="mt-4 whitespace-pre-line leading-8 text-slate-600"><%= @product.description %></p><p class="mt-5 text-sm font-bold text-slate-500">تنبيه: اقرأ النشرة الداخلية واستشر الطبيب أو الصيدلي قبل الاستخدام.</p></section>
  <% if @previous_product || @next_product %><nav aria-label="التنقل بين منتجات القسم" class="mt-6 grid grid-cols-2 gap-3"><div><% if @previous_product %><%= link_to product_path(@previous_product), class: "block rounded-2xl border border-slate-200 bg-white p-4 hover:border-pharmacy-500" do %><span class="text-xs text-slate-500">المنتج السابق</span><span class="mt-1 block truncate font-black"><%= @previous_product.name %></span><% end %><% end %></div><div><% if @next_product %><%= link_to product_path(@next_product), class: "block rounded-2xl border border-slate-200 bg-white p-4 text-left hover:border-pharmacy-500" do %><span class="text-xs text-slate-500">المنتج التالي</span><span class="mt-1 block truncate font-black"><%= @next_product.name %></span><% end %><% end %></div></nav><% end %>
  <% if @related_products.any? %><section class="mt-14"><h2 class="text-2xl font-black">قد يعجبك أيضًا</h2><div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4"><%= render partial: "product_card", collection: @related_products, as: :product %></div></section><% end %>
  <section data-recently-viewed-target="section" class="mt-14 hidden"><h2 class="text-2xl font-black">شوهدت مؤخرًا</h2><div class="mt-6 flex gap-4 overflow-x-auto pb-3"><%= render partial: "compact_product_card", collection: @recent_candidates, as: :product %></div></section>
</div>
