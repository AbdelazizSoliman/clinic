<% content_for :title, "الإشعارات | صيدليتي" %>
<div class="mx-auto max-w-4xl px-4 py-12"><div class="flex items-center justify-between"><h1 class="text-3xl font-black">الإشعارات</h1><%= button_to "تعليم الكل كمقروء", mark_all_read_notifications_path, method: :patch, class: "rounded-xl border px-4 py-2 font-bold" if @notifications.any? %></div><div class="mt-6 grid gap-3"><% @notifications.each do |notification| %><article class="rounded-2xl bg-white p-5 shadow-sm <%= 'border-r-4 border-pharmacy-500' unless notification.read_at %>"><div class="flex justify-between gap-4"><div><h2 class="font-black"><%= notification.title %></h2><p class="mt-1 text-sm text-slate-600"><%= notification.body %></p><small class="mt-2 block text-slate-400"><%= l(notification.created_at, format: :short) %></small></div><% unless notification.read_at %><%= button_to "تعليم كمقروء", notification_path(notification), method: :patch, class: "text-sm font-bold text-pharmacy-700" %><% end %></div></article><% end %></div><% if @notifications.empty? %><p class="mt-8 rounded-2xl bg-white p-10 text-center">لا توجد إشعارات حتى الآن.</p><% end %></div>
