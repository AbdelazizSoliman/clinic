<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur">
  <div class="bg-pharmacy-700 px-4 py-2 text-center text-xs font-medium text-white sm:text-sm">توصيل مجاني للطلبات أكثر من 500 ج.م داخل القاهرة والجيزة</div>
  <nav aria-label="التنقل الرئيسي" class="mx-auto flex max-w-7xl flex-wrap items-center gap-4 px-4 py-4 sm:px-6 lg:px-8">
    <%= link_to root_path, class: "flex shrink-0 items-center gap-2", aria: { label: "#{PharmacySetting.current.pharmacy_name} - الرئيسية" } do %>
      <% if PharmacySetting.current.logo.attached? %><%= image_tag PharmacySetting.current.logo, class: "size-10 rounded-xl object-cover", alt: "شعار #{PharmacySetting.current.pharmacy_name}" %><% else %><span class="grid size-10 place-items-center rounded-xl bg-pharmacy-600 text-2xl font-black text-white" aria-hidden="true">+</span><% end %>
      <span class="text-xl font-black text-pharmacy-900"><%= PharmacySetting.current.pharmacy_name %></span>
    <% end %>
    <%= form_with url: products_path, method: :get, class: "order-3 flex w-full flex-1 sm:order-none sm:w-auto", role: "search" do |form| %>
      <%= form.label :q, "ابحث عن دواء أو منتج", class: "sr-only" %>
      <%= form.search_field :q, value: params[:q], placeholder: "ابحث عن دواء، فيتامين أو منتج...", class: "w-full rounded-r-xl border border-slate-300 bg-slate-50 px-4 py-3 text-sm focus:border-pharmacy-500" %>
      <%= form.button "بحث", class: "rounded-l-xl bg-pharmacy-600 px-5 py-3 text-sm font-bold text-white hover:bg-pharmacy-700" %>
    <% end %>
    <div class="mr-auto flex items-center gap-2">
      <% if user_signed_in? %><%= link_to account_path, class: "rounded-xl p-2 text-sm font-bold text-slate-700 hover:bg-slate-100", aria: { label: "حساب #{current_user.full_name}" } do %>👤 <span class="hidden lg:inline"><%= current_user.first_name %></span><% end %><%= button_to "خروج", destroy_user_session_path, method: :delete, class: "hidden text-xs font-bold text-slate-600 sm:block" %><% else %><%= link_to "دخول", new_user_session_path, class: "rounded-xl p-2 text-sm font-bold text-slate-700 hover:bg-slate-100" %><%= link_to "حساب جديد", new_user_registration_path, class: "hidden text-xs font-bold text-pharmacy-700 sm:block" if PharmacySetting.current.customer_registration_enabled? %><% end %>
      <% if user_signed_in? %><%= link_to wishlist_path, class: "relative rounded-xl p-2 text-sm font-bold text-slate-700 hover:bg-slate-100" do %>♥ <span class="hidden lg:inline">المفضلة</span><%= render "wishlists/badge", count: wishlist_count %><% end %><% else %><%= link_to wishlist_path, data: { controller: "shopping-count", shopping_count_type_value: "wishlist" }, class: "relative rounded-xl p-2 text-sm font-bold text-slate-700 hover:bg-slate-100", aria: { label: "المفضلة، 0 منتجات" } do %>♥ <span class="hidden lg:inline">المفضلة</span><span data-shopping-count-target="badge" class="absolute -left-1 -top-1 grid size-5 place-items-center rounded-full bg-rose-500 text-xs text-white opacity-0 transition-opacity">0</span><% end %><% end %>
      <% if user_signed_in? %><%= link_to notifications_path, class: "relative rounded-xl p-2", aria: { label: "الإشعارات، #{current_user.notifications.unread.count} غير مقروءة" } do %>🔔<% if current_user.notifications.unread.any? %><span class="absolute -left-1 -top-1 grid size-5 place-items-center rounded-full bg-rose-600 text-xs text-white"><%= current_user.notifications.unread.count %></span><% end %><% end %><% end %>
      <%= render "shared/cart_drawer" %>
    </div>
  </nav>
  <div class="border-t border-slate-100">
    <div class="mx-auto flex max-w-7xl gap-6 overflow-x-auto px-4 py-3 text-sm font-bold text-slate-600 sm:px-6 lg:px-8">
      <%= link_to "كل المنتجات", products_path, class: "whitespace-nowrap hover:text-pharmacy-600" %>
      <% Category.active.order(:position, :id).limit(6).each do |category| %>
        <%= link_to category.name, category_path(category), class: "whitespace-nowrap hover:text-pharmacy-600" %>
      <% end %>
    </div>
  </div>
</header>
