<div data-controller="cart-drawer">
  <button type="button" data-cart-drawer-target="trigger" data-action="cart-drawer#open" aria-expanded="false" aria-controls="cart-drawer" data-controller="shopping-count" data-shopping-count-type-value="cart" class="relative rounded-xl p-2 text-sm font-bold text-slate-700 hover:bg-slate-100">
    🛒 <span class="hidden lg:inline">السلة</span><span data-shopping-count-target="badge" class="absolute -left-1 -top-1 grid size-5 place-items-center rounded-full bg-rose-500 text-xs text-white transition-opacity">0</span>
  </button>
  <div data-cart-drawer-target="backdrop" data-action="click->cart-drawer#backdrop" class="fixed inset-0 z-[70] hidden bg-slate-950/50 backdrop-blur-sm" aria-hidden="true"></div>
  <aside id="cart-drawer" data-cart-drawer-target="panel" role="dialog" aria-modal="true" aria-labelledby="cart-drawer-title" class="fixed inset-y-0 right-0 z-[75] flex w-[min(92vw,28rem)] translate-x-full flex-col bg-slate-50 shadow-2xl transition-transform duration-300">
    <header class="flex items-center justify-between border-b bg-white p-5"><div><h2 id="cart-drawer-title" class="text-xl font-black">سلة التسوق</h2><p class="mt-1 text-sm text-slate-500"><span data-cart-drawer-target="count">0</span> قطعة</p></div><button type="button" data-cart-drawer-target="close" data-action="cart-drawer#close" class="grid size-11 place-items-center rounded-full hover:bg-slate-100" aria-label="إغلاق سلة التسوق">✕</button></header>
    <div class="flex-1 overflow-y-auto p-4">
      <div data-cart-drawer-target="prescription" class="mb-3 hidden rounded-xl bg-amber-50 p-3 text-sm font-bold text-amber-900">⚕ تحتوي السلة على منتج يحتاج مراجعة روشتة قبل التأكيد.</div>
      <div data-cart-drawer-target="items" data-action="click->cart-drawer#itemAction change->cart-drawer#itemAction" class="space-y-3"></div>
      <div data-cart-drawer-target="empty" class="py-16 text-center"><div class="text-5xl">🛒</div><h3 class="mt-4 text-xl font-black">سلتك فارغة</h3><p class="mt-2 text-sm text-slate-500">أضف منتجاتك الصحية المفضلة وارجع هنا.</p><%= link_to "ابدأ التسوق", products_path, class: "mt-5 inline-block rounded-xl bg-pharmacy-600 px-5 py-3 font-black text-white" %></div>
    </div>
    <footer data-cart-drawer-target="content" class="hidden border-t bg-white p-5"><div class="flex justify-between text-lg font-black"><span>الإجمالي التقديري</span><span data-cart-drawer-target="subtotal">0 ج.م</span></div><p class="mt-2 text-xs text-slate-500">تُحدد رسوم التوصيل لاحقًا حسب العنوان.</p><%= link_to "متابعة إلى الدفع التجريبي", checkout_path, class: "mt-4 block rounded-xl bg-pharmacy-600 px-5 py-3 text-center font-black text-white" %><%= link_to "عرض السلة كاملة", cart_path, class: "mt-2 block text-center text-sm font-bold text-pharmacy-700" %><button type="button" data-action="cart-drawer#clear" class="mt-3 w-full text-center text-xs font-bold text-rose-600">إفراغ السلة</button></footer>
  </aside>
</div>
