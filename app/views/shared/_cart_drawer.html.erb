<div data-controller="cart-drawer">
  <button type="button" data-cart-drawer-target="trigger" data-action="cart-drawer#open" aria-expanded="false" aria-controls="cart-drawer" class="relative rounded-xl p-2 text-sm font-bold text-slate-700 hover:bg-slate-100">
    🛒 <span class="hidden lg:inline">السلة</span><%= render "carts/badge", cart: current_cart %>
  </button>
  <div data-cart-drawer-target="backdrop" data-action="click->cart-drawer#backdrop" class="fixed inset-0 z-[70] hidden bg-slate-950/50 backdrop-blur-sm" aria-hidden="true"></div>
  <aside id="cart-drawer" data-cart-drawer-target="panel" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="cart-drawer-title" class="fixed inset-y-0 right-0 z-[75] flex w-[min(92vw,28rem)] translate-x-full flex-col bg-slate-50 shadow-2xl transition-transform duration-300">
    <header class="flex items-center justify-between border-b bg-white p-5"><div><h2 id="cart-drawer-title" class="text-xl font-black">سلة التسوق</h2><p class="mt-1 text-sm text-slate-500"><%= render "carts/drawer_count", cart: current_cart %> قطعة</p></div><button type="button" data-cart-drawer-target="close" data-action="cart-drawer#close" class="grid size-11 place-items-center rounded-full hover:bg-slate-100" aria-label="إغلاق سلة التسوق">✕</button></header>
    <%= render "carts/drawer_content", cart: current_cart %>
  </aside>
</div>
