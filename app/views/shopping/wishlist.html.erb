<% content_for :title, "المفضلة | صيدليتي" %>
<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8" data-controller="wishlist-page">
  <nav aria-label="مسار التنقل" class="text-sm text-slate-500"><%= link_to "الرئيسية", root_path %> / <span>المفضلة</span></nav>
  <div class="mt-6 flex items-end justify-between gap-3"><div><h1 class="text-3xl font-black">قائمة المفضلة</h1><p class="mt-2 text-slate-600"><span data-wishlist-page-target="count">0</span> منتج محفوظ على هذا المتصفح</p></div><button type="button" data-action="wishlist-page#clear" class="text-sm font-bold text-rose-600">مسح المفضلة</button></div>
  <div data-wishlist-page-target="empty" class="mt-10 rounded-3xl border border-dashed border-slate-300 bg-white p-12 text-center"><div class="text-6xl">♡</div><h2 class="mt-4 text-2xl font-black">لم تحفظ منتجات بعد</h2><p class="mt-2 text-slate-500">اضغط رمز القلب على أي منتج للرجوع إليه بسهولة.</p><%= link_to "اكتشف المنتجات", products_path, class: "mt-6 inline-block rounded-xl bg-pharmacy-600 px-6 py-3 font-black text-white" %></div>
  <div data-wishlist-page-target="content" class="mt-10 hidden grid grid-cols-1 gap-5 min-[420px]:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
    <% @products.each do |product| %><div data-wishlist-page-target="item" data-product-id="<%= product.id %>" class="hidden"><%= render "products/product_card", product: product %></div><% end %>
  </div>
</div>
