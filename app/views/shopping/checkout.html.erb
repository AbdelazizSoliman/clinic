<% content_for :title, "الدفع التجريبي | صيدليتي" %>
<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8" data-controller="checkout">
  <nav aria-label="مسار التنقل" class="text-sm text-slate-500"><%= link_to "الرئيسية", root_path %> / <%= link_to "السلة", cart_path %> / <span>الدفع التجريبي</span></nav>
  <div class="mt-6"><span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-black text-amber-900">واجهة تجريبية فقط</span><h1 class="mt-3 text-3xl font-black">إتمام بيانات الطلب</h1><p class="mt-2 text-slate-600">لن تُحفظ البيانات ولن يتم إنشاء طلب أو تحصيل أي مبلغ.</p></div>
  <div data-checkout-target="empty" class="mt-10 hidden rounded-3xl bg-white p-12 text-center"><h2 class="text-2xl font-black">السلة فارغة</h2><%= link_to "العودة للتسوق", products_path, class: "mt-5 inline-block rounded-xl bg-pharmacy-600 px-6 py-3 font-black text-white" %></div>
  <form data-checkout-target="form" data-action="submit->checkout#submit" class="mt-8 grid gap-8 lg:grid-cols-[minmax(0,1fr)_23rem]" novalidate>
    <div class="space-y-6">
      <fieldset class="rounded-3xl bg-white p-6 shadow-sm"><legend class="px-2 text-xl font-black">1. معلومات التواصل</legend><div class="mt-4 grid gap-4 sm:grid-cols-2"><div><label for="full-name" class="mb-2 block text-sm font-bold">الاسم الكامل *</label><input id="full-name" name="full_name" required autocomplete="name" class="w-full rounded-xl border border-slate-300 px-4 py-3"></div><div><label for="mobile" class="mb-2 block text-sm font-bold">رقم الموبايل *</label><input id="mobile" name="mobile" required inputmode="tel" pattern="[0-9+ ]{8,15}" autocomplete="tel" class="w-full rounded-xl border border-slate-300 px-4 py-3"></div><div class="sm:col-span-2"><label for="email" class="mb-2 block text-sm font-bold">البريد الإلكتروني</label><input id="email" type="email" autocomplete="email" class="w-full rounded-xl border border-slate-300 px-4 py-3"></div></div></fieldset>
      <fieldset class="rounded-3xl bg-white p-6 shadow-sm"><legend class="px-2 text-xl font-black">2. عنوان التوصيل</legend><div class="mt-4 grid gap-4 sm:grid-cols-2"><% [["governorate", "المحافظة *"], ["city", "المدينة أو المنطقة *"], ["street", "الشارع *"], ["building", "رقم المبنى *"], ["floor", "الدور"], ["apartment", "الشقة"]].each do |id, label| %><div><label for="<%= id %>" class="mb-2 block text-sm font-bold"><%= label %></label><input id="<%= id %>" <%= "required" if label.include?("*") %> class="w-full rounded-xl border border-slate-300 px-4 py-3"></div><% end %><div class="sm:col-span-2"><label for="landmark" class="mb-2 block text-sm font-bold">علامة مميزة</label><input id="landmark" class="w-full rounded-xl border border-slate-300 px-4 py-3"></div><div class="sm:col-span-2"><label for="notes" class="mb-2 block text-sm font-bold">ملاحظات التوصيل</label><textarea id="notes" rows="3" class="w-full rounded-xl border border-slate-300 px-4 py-3"></textarea></div></div></fieldset>
      <fieldset class="rounded-3xl bg-white p-6 shadow-sm"><legend class="px-2 text-xl font-black">3. طريقة التوصيل</legend><div class="mt-4 grid gap-3"><% [["standard", "توصيل عادي", "خلال 1–2 يوم عمل"], ["scheduled", "توصيل مجدول", "اختر موعدًا لاحقًا — تجريبي"], ["pickup", "استلام من الصيدلية", "خيار قادم قريبًا"]].each_with_index do |(value, title, detail), index| %><label class="flex cursor-pointer gap-3 rounded-xl border p-4"><input type="radio" name="delivery" value="<%= value %>" <%= "checked" if index.zero? %>><span><strong class="block"><%= title %></strong><small class="text-slate-500"><%= detail %></small></span></label><% end %></div></fieldset>
      <fieldset class="rounded-3xl bg-white p-6 shadow-sm"><legend class="px-2 text-xl font-black">4. طريقة الدفع</legend><div class="mt-4 space-y-3"><label class="flex gap-3 rounded-xl border p-4"><input type="radio" name="payment" checked><span><strong>الدفع عند الاستلام</strong><small class="block text-slate-500">اختيار تجريبي بدون تحصيل</small></span></label><label class="flex gap-3 rounded-xl border p-4 text-slate-500"><input type="radio" name="payment"><span>بطاقة بنكية — واجهة فقط، لا تدخل بيانات حساسة</span></label><label class="flex gap-3 rounded-xl border p-4 text-slate-500"><input type="radio" name="payment"><span>محفظة رقمية — قريبًا</span></label></div></fieldset>
      <section data-checkout-target="prescription" class="hidden rounded-3xl border border-amber-200 bg-amber-50 p-6"><h2 class="text-xl font-black text-amber-950">5. مراجعة الروشتة</h2><p class="mt-2 leading-7 text-amber-900">سيطلب الصيدلي روشتة صالحة ويراجعها مهنيًا قبل تأكيد المنتجات المعنية.</p><button type="button" disabled title="رفع الروشتة غير متاح في النسخة التجريبية" class="mt-4 cursor-not-allowed rounded-xl border border-amber-300 bg-white px-5 py-3 font-bold text-amber-900 opacity-70">📎 رفع الروشتة — قريبًا</button></section>
    </div>
    <aside class="self-start rounded-3xl bg-white p-5 shadow-sm lg:sticky lg:top-44"><h2 class="text-xl font-black">6. مراجعة الطلب</h2><div data-checkout-target="items" class="mt-4 max-h-96 space-y-3 overflow-y-auto"></div><div class="mt-5 flex justify-between border-t pt-4 text-lg font-black"><span>الإجمالي التقديري</span><span data-checkout-target="subtotal">0 ج.م</span></div><p class="mt-2 text-xs text-slate-500">الأسعار للتوضيح ولا تُعد عرضًا نهائيًا.</p><button type="submit" class="mt-5 w-full rounded-xl bg-pharmacy-600 px-5 py-4 font-black text-white">محاكاة إتمام الطلب</button></aside>
  </form>
  <div data-checkout-target="completion" class="fixed inset-0 z-[95] hidden bg-slate-950/60 p-4"><div role="dialog" aria-modal="true" aria-labelledby="completion-title" class="mx-auto mt-24 max-w-md rounded-3xl bg-white p-8 text-center shadow-2xl"><div class="text-6xl">✓</div><h2 id="completion-title" class="mt-4 text-2xl font-black">اكتملت المحاكاة بنجاح</h2><p class="mt-3 leading-7 text-slate-600">لم يتم إنشاء طلب أو حفظ بيانات أو تحصيل دفعة. هذه نهاية تجربة الواجهة فقط.</p><button type="button" data-action="checkout#close" class="mt-6 rounded-xl bg-pharmacy-600 px-6 py-3 font-black text-white">حسنًا</button></div></div>
  <section class="mt-16"><h2 class="text-2xl font-black">عروض قد تهمك</h2><div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4"><%= render partial: "products/product_card", collection: @recommendations, as: :product %></div></section>
</div>
