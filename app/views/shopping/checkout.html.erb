<% content_for :title, "الدفع التجريبي | صيدليتي" %>
<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8" data-controller="checkout">
  <nav aria-label="مسار التنقل" class="text-sm text-slate-500"><%= link_to "الرئيسية", root_path %> / <%= link_to "السلة", cart_path %> / <span>الدفع التجريبي</span></nav>
  <div class="mt-6"><span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-black text-amber-900">واجهة تجريبية فقط</span><h1 class="mt-3 text-3xl font-black">تجهيز بيانات الطلب</h1><p class="mt-2 text-slate-600">لن يتم إنشاء طلب أو خصم مخزون أو تحصيل أي مبلغ في هذه المرحلة.</p><ol class="mt-6 grid grid-cols-2 gap-2 text-xs font-bold sm:grid-cols-6"><% ["العميل", "العنوان", "التوصيل", "الروشتة", "الدفع", "المراجعة"].each_with_index do |step, index| %><li class="rounded-xl bg-white p-3"><span class="text-pharmacy-600"><%= index + 1 %></span> <%= step %></li><% end %></ol></div>
  <% if @cart.blank? || @cart.valid_items.empty? %><div class="mt-10 rounded-3xl bg-white p-12 text-center"><h2 class="text-2xl font-black">السلة فارغة أو لا تحتوي منتجات متاحة</h2><%= link_to "العودة للتسوق", products_path, class: "mt-5 inline-block rounded-xl bg-pharmacy-600 px-6 py-3 font-black text-white" %></div><% else %>
  <% if @cart_issues.any? %><section class="mt-6 rounded-2xl border border-rose-200 bg-rose-50 p-5" role="alert"><h2 class="font-black text-rose-900">تحتاج السلة إلى مراجعة</h2><ul class="mt-2 list-inside list-disc text-sm text-rose-800"><% @cart_issues.each do |issue| %><li><%= issue %></li><% end %></ul><%= link_to "تصحيح السلة", cart_path, class: "mt-3 inline-block font-black underline" %></section><% end %><% unless @readiness.ready %><section class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 p-5" aria-live="polite"><h2 class="font-black text-amber-950">خطوات مطلوبة قبل إنشاء طلب مستقبلًا</h2><ul class="mt-2 list-inside list-disc text-sm text-amber-900"><% @readiness.errors.each do |error| %><li><%= error %></li><% end %></ul></section><% end %>
  <form data-checkout-target="form" data-action="submit->checkout#submit" class="mt-8 grid gap-8 lg:grid-cols-[minmax(0,1fr)_23rem]" novalidate>
    <div class="space-y-6">
      <fieldset class="rounded-3xl bg-white p-6 shadow-sm"><legend class="px-2 text-xl font-black">1. معلومات العميل</legend><div class="mt-4 grid gap-4 sm:grid-cols-2"><div><span class="block text-sm font-bold">الاسم</span><p class="mt-2"><%= current_user.full_name %></p></div><div><span class="block text-sm font-bold">رقم الموبايل</span><p class="mt-2" dir="ltr"><%= current_user.mobile_number %></p></div><div class="sm:col-span-2"><span class="block text-sm font-bold">البريد الإلكتروني</span><p class="mt-2" dir="ltr"><%= current_user.email %></p><%= link_to "تعديل بيانات الحساب", edit_account_path, class: "mt-2 inline-block text-sm font-bold text-pharmacy-700" %></div></div></fieldset>
      <fieldset class="rounded-3xl bg-white p-6 shadow-sm"><legend class="px-2 text-xl font-black">2. عنوان التوصيل</legend><% if @addresses.empty? %><div class="mt-4 rounded-2xl border border-dashed p-6 text-center"><p class="font-black">أضف عنوانًا للمتابعة</p><p class="mt-2 text-sm text-slate-500">سيصبح أول عنوان نشط هو العنوان الافتراضي.</p></div><% else %><div class="mt-4 grid gap-3"><% @addresses.each do |address| %><label class="flex cursor-pointer gap-3 rounded-2xl border p-4 has-[:checked]:border-pharmacy-500 has-[:checked]:bg-pharmacy-50"><input type="radio" name="address_id" value="<%= address.id %>" required <%= "checked" if address == @selected_address %>><span class="min-w-0"><strong><%= address.label %></strong><% if address.default? %><span class="mr-2 rounded-full bg-pharmacy-100 px-2 py-1 text-xs">افتراضي</span><% end %><span class="mt-1 block text-sm"><%= address.recipient_name %> · <span dir="ltr"><%= address.mobile_number %></span></span><span class="mt-1 block text-sm text-slate-600"><%= address.summary %></span><span class="mt-2 block text-xs font-bold <%= Checkout::DeliveryAreaPolicy.supported?(address) ? "text-emerald-700" : "text-amber-700" %>"><%= Checkout::DeliveryAreaPolicy.supported?(address) ? "ضمن نطاق التوصيل التجريبي" : "خارج نطاق التوصيل التجريبي حاليًا" %></span></span></label><% end %></div><% end %><div class="mt-4 flex gap-4"><%= link_to "إضافة عنوان", new_account_address_path, data: { turbo_frame: "checkout_address_form" }, class: "font-black text-pharmacy-700" %><% if @selected_address %><%= link_to "تعديل المحدد", edit_account_address_path(@selected_address), class: "font-bold text-slate-600" %><% end %></div><%= turbo_frame_tag "checkout_address_form" %></fieldset>
      <fieldset class="rounded-3xl bg-white p-6 shadow-sm"><legend class="px-2 text-xl font-black">3. طريقة التوصيل</legend><div class="mt-4 grid gap-3"><% [["standard", "توصيل عادي", "خلال 1–2 يوم عمل"], ["scheduled", "توصيل مجدول", "اختر موعدًا لاحقًا — تجريبي"], ["pickup", "استلام من الصيدلية", "خيار قادم قريبًا"]].each_with_index do |(value, title, detail), index| %><label class="flex cursor-pointer gap-3 rounded-xl border p-4"><input type="radio" name="delivery" value="<%= value %>" <%= "checked" if index.zero? %>><span><strong class="block"><%= title %></strong><small class="text-slate-500"><%= detail %></small></span></label><% end %></div></fieldset>
      <fieldset class="rounded-3xl bg-white p-6 shadow-sm"><legend class="px-2 text-xl font-black">4. طريقة الدفع</legend><div class="mt-4 space-y-3"><label class="flex gap-3 rounded-xl border p-4"><input type="radio" name="payment" checked><span><strong>الدفع عند الاستلام</strong><small class="block text-slate-500">اختيار تجريبي بدون تحصيل</small></span></label><label class="flex gap-3 rounded-xl border p-4 text-slate-500"><input type="radio" name="payment"><span>بطاقة بنكية — واجهة فقط، لا تدخل بيانات حساسة</span></label><label class="flex gap-3 rounded-xl border p-4 text-slate-500"><input type="radio" name="payment"><span>محفظة رقمية — قريبًا</span></label></div></fieldset>
      <% if @cart.requires_prescription? %><section class="rounded-3xl border border-amber-200 bg-amber-50 p-6"><h2 class="text-xl font-black text-amber-950">5. مراجعة الروشتة</h2><p class="mt-2 leading-7 text-amber-900">سيطلب الصيدلي روشتة صالحة ويراجعها مهنيًا قبل تأكيد المنتجات المعنية.</p><button type="button" disabled title="رفع الروشتة غير متاح في النسخة التجريبية" class="mt-4 cursor-not-allowed rounded-xl border border-amber-300 bg-white px-5 py-3 font-bold text-amber-900 opacity-70">📎 رفع الروشتة — قريبًا</button></section><% end %>
    </div>
    <aside class="self-start rounded-3xl bg-white p-5 shadow-sm lg:sticky lg:top-44"><h2 class="text-xl font-black">6. مراجعة الطلب</h2><div class="mt-4 max-h-96 space-y-3 overflow-y-auto"><% @cart.valid_items.each do |item| %><article class="flex gap-3 rounded-xl border border-slate-200 p-3"><span class="grid size-14 shrink-0 place-items-center rounded-lg bg-pharmacy-50 text-2xl">💊</span><div class="min-w-0 flex-1"><%= link_to item.product.name, product_path(item.product), class: "block truncate text-sm font-black" %><p class="mt-1 text-xs text-slate-500"><%= item.quantity %> × <%= number_to_currency(item.product.price, unit: "ج.م", format: "%n %u") %></p></div><strong class="text-sm"><%= number_to_currency(item.subtotal_cents / 100.0, unit: "ج.م", format: "%n %u") %></strong></article><% end %></div><div class="mt-5 flex justify-between border-t pt-4 text-lg font-black"><span>الإجمالي التقديري</span><span><%= number_to_currency(@cart.subtotal_cents / 100.0, unit: "ج.م", format: "%n %u") %></span></div><p class="mt-2 text-xs text-slate-500">الأسعار من قاعدة البيانات الحالية ولا تُعد طلبًا نهائيًا.</p><button type="submit" class="mt-5 w-full rounded-xl bg-pharmacy-600 px-5 py-4 font-black text-white">محاكاة إتمام الطلب</button></aside>
  </form>
  <div data-checkout-target="completion" class="fixed inset-0 z-[95] hidden bg-slate-950/60 p-4"><div role="dialog" aria-modal="true" aria-labelledby="completion-title" class="mx-auto mt-24 max-w-md rounded-3xl bg-white p-8 text-center shadow-2xl"><div class="text-6xl">✓</div><h2 id="completion-title" class="mt-4 text-2xl font-black">اكتملت المحاكاة بنجاح</h2><p class="mt-3 leading-7 text-slate-600">لم يتم إنشاء طلب أو حفظ بيانات أو تحصيل دفعة. هذه نهاية تجربة الواجهة فقط.</p><button type="button" data-action="checkout#close" class="mt-6 rounded-xl bg-pharmacy-600 px-6 py-3 font-black text-white">حسنًا</button></div></div>
  <% end %><section class="mt-16"><h2 class="text-2xl font-black">عروض قد تهمك</h2><div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4"><%= render partial: "products/product_card", collection: @recommendations, as: :product %></div></section>
</div>
