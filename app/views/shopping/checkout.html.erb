<% content_for :title, "إتمام الطلب | صيدليتي" %>
<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8" data-controller="checkout">
  <nav aria-label="مسار التنقل" class="text-sm text-slate-500"><%= link_to "الرئيسية", root_path %> / <%= link_to "السلة", cart_path %> / <span>الدفع التجريبي</span></nav>
  <div class="mt-6"><span class="rounded-full bg-pharmacy-100 px-3 py-1 text-xs font-black text-pharmacy-900">إرسال آمن للخادم</span><h1 class="mt-3 text-3xl font-black">إتمام الطلب</h1><p class="mt-2 text-slate-600">سيُحفظ الطلب وتُحجز الكميات عند الإرسال. الدفع عند الاستلام غير مدفوع حتى التسليم.</p><ol class="mt-6 grid grid-cols-2 gap-2 text-xs font-bold sm:grid-cols-6"><% ["العميل", "العنوان", "التوصيل", "الروشتة", "الدفع", "المراجعة"].each_with_index do |step, index| %><li class="rounded-xl bg-white p-3"><span class="text-pharmacy-600"><%= index + 1 %></span> <%= step %></li><% end %></ol></div>
  <% if @cart.blank? || @cart.valid_items.empty? %><div class="mt-10 rounded-3xl bg-white p-12 text-center"><h2 class="text-2xl font-black">السلة فارغة أو لا تحتوي منتجات متاحة</h2><%= link_to "العودة للتسوق", products_path, class: "mt-5 inline-block rounded-xl bg-pharmacy-600 px-6 py-3 font-black text-white" %></div><% else %>
  <% if @cart_issues.any? %><section class="mt-6 rounded-2xl border border-rose-200 bg-rose-50 p-5" role="alert"><h2 class="font-black text-rose-900">تحتاج السلة إلى مراجعة</h2><ul class="mt-2 list-inside list-disc text-sm text-rose-800"><% @cart_issues.each do |issue| %><li><%= issue %></li><% end %></ul><%= link_to "تصحيح السلة", cart_path, class: "mt-3 inline-block font-black underline" %></section><% end %><% unless @readiness.ready %><section class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 p-5" aria-live="polite"><h2 class="font-black text-amber-950">خطوات مطلوبة قبل إنشاء طلب مستقبلًا</h2><ul class="mt-2 list-inside list-disc text-sm text-amber-900"><% @readiness.errors.each do |error| %><li><%= error %></li><% end %></ul></section><% end %>
  <%= form_with url: orders_path, scope: :order, method: :post, multipart: true, data: { checkout_target: "form", action: "submit->checkout#submit" }, class: "mt-8 grid gap-8 lg:grid-cols-[minmax(0,1fr)_23rem]" do |form| %><%= form.hidden_field :submission_token, value: @cart.checkout_submission_token %>
    <div class="space-y-6">
      <fieldset class="rounded-3xl bg-white p-6 shadow-sm"><legend class="px-2 text-xl font-black">1. معلومات العميل</legend><div class="mt-4 grid gap-4 sm:grid-cols-2"><div><span class="block text-sm font-bold">الاسم</span><p class="mt-2"><%= current_user.full_name %></p></div><div><span class="block text-sm font-bold">رقم الموبايل</span><p class="mt-2" dir="ltr"><%= current_user.mobile_number %></p></div><div class="sm:col-span-2"><span class="block text-sm font-bold">البريد الإلكتروني</span><p class="mt-2" dir="ltr"><%= current_user.email %></p><%= link_to "تعديل بيانات الحساب", edit_account_path, class: "mt-2 inline-block text-sm font-bold text-pharmacy-700" %></div></div></fieldset>
      <fieldset class="rounded-3xl bg-white p-6 shadow-sm"><legend class="px-2 text-xl font-black">2. عنوان التوصيل</legend><% if @addresses.empty? %><div class="mt-4 rounded-2xl border border-dashed p-6 text-center"><p class="font-black">أضف عنوانًا للمتابعة</p><p class="mt-2 text-sm text-slate-500">سيصبح أول عنوان نشط هو العنوان الافتراضي.</p></div><% else %><div class="mt-4 grid gap-3"><% @addresses.each do |address| %><label class="flex cursor-pointer gap-3 rounded-2xl border p-4 has-[:checked]:border-pharmacy-500 has-[:checked]:bg-pharmacy-50"><%= form.radio_button :address_id, address.id, required: true, checked: address == @selected_address %><span class="min-w-0"><strong><%= address.label %></strong><% if address.default? %><span class="mr-2 rounded-full bg-pharmacy-100 px-2 py-1 text-xs">افتراضي</span><% end %><span class="mt-1 block text-sm"><%= address.recipient_name %> · <span dir="ltr"><%= address.mobile_number %></span></span><span class="mt-1 block text-sm text-slate-600"><%= address.summary %></span><span class="mt-2 block text-xs font-bold <%= Checkout::DeliveryAreaPolicy.supported?(address) ? "text-emerald-700" : "text-amber-700" %>"><%= Checkout::DeliveryAreaPolicy.supported?(address) ? "ضمن نطاق التوصيل" : "خارج نطاق التوصيل حاليًا" %></span></span></label><% end %></div><% end %><div class="mt-4 flex gap-4"><%= link_to "إضافة عنوان", new_account_address_path, data: { turbo_frame: "checkout_address_form" }, class: "font-black text-pharmacy-700" %><% if @selected_address %><%= link_to "تعديل المحدد", edit_account_address_path(@selected_address), class: "font-bold text-slate-600" %><% end %></div><%= turbo_frame_tag "checkout_address_form" %></fieldset>
      <fieldset class="rounded-3xl bg-white p-6 shadow-sm"><legend class="px-2 text-xl font-black">3. طريقة التوصيل</legend><div class="mt-4 grid gap-3"><% [["standard", "توصيل عادي", "خلال 1–2 يوم عمل"], ["scheduled", "توصيل مجدول", "موعد ينسقه فريق الصيدلية"], ["pharmacy_pickup", "استلام من الصيدلية", "خيار تجهيز فقط في هذه المرحلة"]].each_with_index do |(value, title, detail), index| %><label class="flex cursor-pointer gap-3 rounded-xl border p-4"><%= form.radio_button :delivery_method, value, checked: index.zero? %><span><strong class="block"><%= title %></strong><small class="text-slate-500"><%= detail %></small></span></label><% end %></div><div class="mt-4"><%= form.label :delivery_notes, "ملاحظات التوصيل", class: "mb-2 block text-sm font-bold" %><%= form.text_area :delivery_notes, rows: 2, class: "w-full rounded-xl border px-4 py-3" %></div></fieldset>
      <fieldset class="rounded-3xl bg-white p-6 shadow-sm"><legend class="px-2 text-xl font-black">4. طريقة الدفع</legend><label class="mt-4 flex gap-3 rounded-xl border border-pharmacy-300 bg-pharmacy-50 p-4"><%= form.radio_button :payment_method, "cash_on_delivery", checked: true %><span><strong>الدفع عند الاستلام</strong><small class="block text-slate-500">سيبدأ الطلب غير مدفوع؛ لا يتم تحصيل أي مبلغ الآن.</small></span></label><div class="mt-3 rounded-xl border p-4 text-sm text-slate-400">البطاقة والمحفظة غير متاحتين ولا نجمع أي بيانات دفع.</div></fieldset>
      <% if @cart.requires_prescription? %><section class="rounded-3xl border border-amber-200 bg-amber-50 p-6"><h2 class="text-xl font-black text-amber-950">5. إرسال الروشتة</h2><p class="mt-2 leading-7 text-amber-900">ارفع حتى 5 صور أو ملفات PDF، بحد أقصى 8 ميجابايت لكل ملف. سيظل الطلب بانتظار مراجعة الصيدلي.</p><div class="mt-4"><%= form.label :prescription_files, "ملفات الروشتة *", class: "mb-2 block font-black" %><%= form.file_field :prescription_files, multiple: true, required: true, accept: ".jpg,.jpeg,.png,.webp,.pdf,image/jpeg,image/png,image/webp,application/pdf", class: "block w-full rounded-xl border bg-white p-3" %></div><div class="mt-4"><%= form.label :prescription_notes, "ملاحظات للصيدلي", class: "mb-2 block font-bold" %><%= form.text_area :prescription_notes, rows: 3, class: "w-full rounded-xl border bg-white px-4 py-3" %></div></section><% end %>
    </div>
    <aside class="self-start rounded-3xl bg-white p-5 shadow-sm lg:sticky lg:top-44"><h2 class="text-xl font-black">6. مراجعة الطلب</h2><div class="mt-4 max-h-96 space-y-3 overflow-y-auto"><% @cart.valid_items.each do |item| %><article class="flex gap-3 rounded-xl border border-slate-200 p-3"><span class="grid size-14 shrink-0 place-items-center rounded-lg bg-pharmacy-50 text-2xl">💊</span><div class="min-w-0 flex-1"><%= link_to item.product.name, product_path(item.product), class: "block truncate text-sm font-black" %><p class="mt-1 text-xs text-slate-500"><%= item.quantity %> × <%= number_to_currency(item.product.price, unit: "ج.م", format: "%n %u") %></p></div><strong class="text-sm"><%= number_to_currency(item.subtotal_cents / 100.0, unit: "ج.م", format: "%n %u") %></strong></article><% end %></div><div class="mt-5 flex justify-between border-t pt-4 text-lg font-black"><span>الإجمالي</span><span><%= number_to_currency(@cart.subtotal_cents / 100.0, unit: "ج.م", format: "%n %u") %></span></div><p class="mt-2 text-xs text-slate-500">سيعاد فحص السعر والمخزون داخل معاملة الإرسال. التوصيل مجاني في هذه المرحلة.</p><%= form.submit "إرسال الطلب وحجز المنتجات", data: { checkout_target: "submit" }, class: "mt-5 w-full cursor-pointer rounded-xl bg-pharmacy-600 px-5 py-4 font-black text-white disabled:cursor-wait disabled:opacity-60" %></aside>
  <% end %>
  <% end %><section class="mt-16"><h2 class="text-2xl font-black">عروض قد تهمك</h2><div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4"><%= render partial: "products/product_card", collection: @recommendations, as: :product %></div></section>
</div>
