<% content_for :title, "سلة التسوق | صيدليتي" %>
<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8" data-controller="cart-page">
  <nav aria-label="مسار التنقل" class="text-sm text-slate-500"><%= link_to "الرئيسية", root_path %> / <span>سلة التسوق</span></nav>
  <div class="mt-6 flex items-end justify-between gap-3"><div><h1 class="text-3xl font-black">سلة التسوق</h1><p class="mt-2 text-slate-600"><span data-cart-page-target="count">0</span> قطعة في سلتك المؤقتة</p></div><button type="button" data-action="cart-page#clear" class="text-sm font-bold text-rose-600">إفراغ السلة</button></div>
  <div data-cart-page-target="empty" class="mt-10 rounded-3xl border border-dashed border-slate-300 bg-white p-12 text-center"><div class="text-6xl">🛒</div><h2 class="mt-4 text-2xl font-black">سلة التسوق فارغة</h2><p class="mt-2 text-slate-500">اكتشف احتياجاتك اليومية وأضفها بسهولة.</p><%= link_to "متابعة التسوق", products_path, class: "mt-6 inline-block rounded-xl bg-pharmacy-600 px-6 py-3 font-black text-white" %></div>
  <div data-cart-page-target="content" class="mt-8 hidden grid gap-8 lg:grid-cols-[minmax(0,1fr)_23rem]">
    <section><div data-cart-page-target="attention" class="mb-4 hidden rounded-xl bg-rose-50 p-4 text-sm font-bold text-rose-800">بعض المنتجات لم تعد متوفرة، لذلك استُبعدت من الإجمالي.</div><div data-cart-page-target="prescription" class="mb-4 hidden rounded-xl bg-amber-50 p-4 leading-7 text-amber-900"><strong>مراجعة الروشتة:</strong> تحتوي السلة على منتج يحتاج موافقة صيدلي. يمكنك استكمال الخطوات بأمان وسنوضح المتطلبات قبل التأكيد.</div><div data-cart-page-target="items" data-action="click->cart-page#itemAction change->cart-page#itemAction" class="space-y-4"></div></section>
    <aside class="self-start rounded-3xl bg-white p-6 shadow-sm lg:sticky lg:top-44"><h2 class="text-xl font-black">ملخص الطلب</h2><dl class="mt-5 space-y-4 text-sm"><div class="flex justify-between"><dt>الإجمالي الفرعي</dt><dd data-cart-page-target="subtotal" class="font-black">0 ج.م</dd></div><div class="flex justify-between text-pharmacy-700"><dt>الخصم التجريبي</dt><dd data-cart-page-target="discount" class="font-black">—</dd></div><div class="flex justify-between"><dt>رسوم التوصيل</dt><dd>تُحدد لاحقًا</dd></div><div class="flex justify-between border-t pt-4 text-lg font-black"><dt>الإجمالي التقديري</dt><dd data-cart-page-target="total">0 ج.م</dd></div></dl>
      <form data-controller="promo-code" data-action="submit->promo-code#apply" class="mt-6"><label for="promo-code" class="mb-2 block text-sm font-black">كود الخصم</label><div class="flex"><input id="promo-code" data-promo-code-target="input" placeholder="جرّب WELCOME10" class="min-w-0 flex-1 rounded-r-xl border border-slate-300 px-3 py-2.5 uppercase"><button data-promo-code-target="button" class="rounded-l-xl bg-slate-800 px-4 text-sm font-black text-white">تطبيق</button></div><p data-promo-code-target="success" class="mt-2 hidden text-sm font-bold text-pharmacy-700">✓ تم تطبيق خصم 10٪ <button type="button" data-action="promo-code#remove" class="underline">إزالة</button></p><p data-promo-code-target="error" class="mt-2 hidden text-sm font-bold text-rose-600">الكود غير صحيح. استخدم WELCOME10 للتجربة.</p></form>
      <%= link_to "الانتقال إلى الدفع التجريبي", checkout_path, class: "mt-6 block rounded-xl bg-pharmacy-600 px-5 py-4 text-center font-black text-white" %><p class="mt-3 text-center text-xs text-slate-500">🔒 تجربة آمنة — لن يُنشأ طلب أو تُحصّل دفعة</p><%= link_to "← متابعة التسوق", products_path, class: "mt-4 block text-center text-sm font-bold text-pharmacy-700" %>
    </aside>
  </div>
  <section class="mt-16"><h2 class="text-2xl font-black">قد تحتاج أيضًا</h2><div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4"><%= render partial: "products/product_card", collection: @recommendations, as: :product %></div></section>
</div>
