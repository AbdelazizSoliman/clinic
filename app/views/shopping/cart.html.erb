<% content_for :title, "سلة التسوق | صيدليتي" %>
<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
  <nav aria-label="مسار التنقل" class="text-sm text-slate-500"><%= link_to "الرئيسية", root_path %> / <span>سلة التسوق</span></nav>
  <div class="mt-6 flex items-end justify-between gap-3"><div><h1 class="text-3xl font-black">سلة التسوق</h1><p class="mt-2 text-slate-600"><%= @cart&.total_quantity.to_i %> قطعة</p></div><% if @cart&.items&.any? %><%= button_to "إفراغ السلة", clear_cart_path, method: :post, class: "text-sm font-bold text-rose-600", form: { data: { turbo_confirm: "هل تريد إفراغ سلة التسوق بالكامل؟" } } %><% end %></div>
  <%= render "carts/page_state", cart: @cart %>
  <section class="mt-16"><h2 class="text-2xl font-black">قد تحتاج أيضًا</h2><div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4"><%= render partial: "products/product_card", collection: @recommendations, as: :product %></div></section>
</div>
